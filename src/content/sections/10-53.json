    {
      "level": "B",
      "levelType": "major",
      "text": "Theories of Being and existence",
      "children": [
        {
          "level": "1",
          "levelType": "numeric",
          "text": "Different types of metaphysical theory: Platonism; Aristotelianism; Thomism; Cartesianism; Idealism; Materialism --dialectical Materialism, Atomism, and Naturalism; Pythagoreanism; Organismic dynamism",
          "children": []
        },
        {
          "level": "2",
          "levelType": "numeric",
          "text": "Different views concerning the existence, attributes, and knowledge of God: agnosticism, atheism, Deism, fideism, humanism, pantheism, theism",
          "children": []
        },
        {
          "level": "3",
          "levelType": "numeric",
          "text": "Different conceptions of man as knower, doer, and maker: Existentialism, humanism, Phenomenology, Pragmatism, rationalism, irrationalism",
          "children": []
        },
        {
          "level": "4",
          "levelType": "numeric",
          "text": "Different views concerning the existence of the mind and its relation to the body: Materialism, dualism, immaterialism",
          "children": []
        }
      ]
    },
    {
      "level": "C",
      "levelType": "major",
      "text": "Theories of thought, knowledge, and faculties of mind",
      "children": [
        {
          "level": "1",
          "levelType": "numeric",
          "text": "Different conceptions of the object of knowledge: sense-datum theory, Phenomenalism, Idealism, Realism",
          "children": []
        },
        {
          "level": "2",
          "levelType": "numeric",
          "text": "Different conceptions of the validity of knowledge: Kantianism, positivism, pragmatism, Skepticism",
          "children": []
        },
        {
          "level": "3",
          "levelType": "numeric",
          "text": "Different views of the sources or foundations of knowledge: rationalism, Empiricism",
          "children": []
        },
        {
          "level": "4",
          "levelType": "numeric",
          "text": "Different views of the status of the universal: realism, conceptualism, nominalism",
          "children": []
        },
        {
          "level": "5",
          "levelType": "numeric",
          "text": "Different views of the epistemic status of scientific theories; e.g., realism, conventionalism, and operationalism; the Unity of Science movement; reductionism",
          "children": []
        }
      ]
    },
    {
      "level": "D",
      "levelType": "major",
      "text": "Theories of conduct",
      "children": [
        {
          "level": "1",
          "levelType": "numeric",
          "text": "Metaethical theories: intuitionism, naturalism, noncognitivism, good reasons theories",
          "children": []
        },
        {
          "level": "2",
          "levelType": "numeric",
          "text": "Deontological theories: rationalism, intuitionism, Existentialism",
          "children": []
        }
      ]
    }
  ],
