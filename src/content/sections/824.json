          "children": []
        },
        {
          "level": "3",
          "levelType": "numeric",
          "text": "Buddhist philosophy: the role and contribution of systematic reflective thought",
          "children": []
        },
        {
          "level": "4",
          "levelType": "numeric",
          "text": "Buddhist mysticism: universal characteristics; regional and historical variations; goals, techniques, and approaches",
          "children": []
        }
      ]
    },
    {
      "level": "C",
      "levelType": "major",
      "text": "Beliefs, practices, and institutions of Buddhism",
      "children": [
        {
          "level": "1",
          "levelType": "numeric",
          "text": "Traditional beliefs and doctrines",
          "children": [
            {
              "level": "a",
              "levelType": "lowercase",
              "text": "Views of the nature of reality; e.g., the impermanence of all existence, the absence of self, the underlying state of suffering and its causes",
              "children": []
            },
            {
              "level": "b",
              "levelType": "lowercase",
              "text": "The Eightfold Path to salvation or release",
              "children": []
            },
            {
              "level": "c",
              "levelType": "lowercase",
              "text": "The goal of the Eightfold Path: Nirvana",
              "children": []
            },
            {
              "level": "d",
              "levelType": "lowercase",
              "text": "The Threefold Refuge-- in the Buddha, the doctrine, and the community",
              "children": []
            },
            {
              "level": "e",
              "levelType": "lowercase",
              "text": "Views of the gods, spirits, and demons: the role of miraculous powers",
              "children": []
            }
          ]
        },
        {
          "level": "2",
          "levelType": "numeric",
          "text": "The main forms of Buddhism",
          "children": [
            {
              "level": "a",
              "levelType": "lowercase",
              "text": "The Theravada school and other ancient schools",
              "children": [
                {
                  "level": "i",
                  "levelType": "lowercase",
                  "text": "Views of the nature of things: cosmology, the classification of dharmas",
                  "children": []
                },
                {
                  "level": "ii",
                  "levelType": "roman",
                  "text": "The emphasis on self-cultivation and self-salvation: the stages leading to arhatship, the levels of meditation",
                  "children": []
                },
                {
                  "level": "iii",
                  "levelType": "roman",
                  "text": "Doctrines concerning Buddha and Buddhahood",
                  "children": []
                },
                {
                  "level": "iv",
                  "levelType": "roman",
                  "text": "Characteristics of the individual ancient and transitional schools",
                  "children": []
                }
              ]
            },
            {
              "level": "b",
              "levelType": "lowercase",
              "text": "The Mahayana version",
              "children": [
                {
                  "level": "i",
                  "levelType": "lowercase",
                  "text": "Views of the nature of absolute reality: the ultimate realization of the meditative quest",
                  "children": []
                },
                {
                  "level": "ii",
                  "levelType": "roman",
                  "text": "Views of the transcendence of the Buddha: the three aspects of the Buddha, the bodhisattva ideal",
                  "children": []
                },
                {
                  "level": "iii",
                  "levelType": "roman",
                  "text": "Characteristics of the individual Mahayana schools; e.g., Madhyamika, Yogacara, Avatamsaka, Zen, devotional schools",
                  "children": []
                }
              ]
            },
            {
              "level": "c",
              "levelType": "lowercase",
              "text": "Esoteric Buddhism: Tantrism, Tibetan Buddhism, Shingon",
              "children": []
            }
          ]
        },
