    {
      "level": "A",
      "levelType": "major",
      "text": "History of Buddhism",
      "children": [
        {
          "level": "1",
          "levelType": "numeric",
          "text": "The cultural context: its background in Hinduism; its geographical, ethnic, and cultural base [see also 823]",
          "children": []
        },
        {
          "level": "2",
          "levelType": "numeric",
          "text": "The founding of Buddhism: the life, work, and teachings of Siddhartha Gautama (6th-5th century bc)",
          "children": []
        },
        {
          "level": "3",
          "levelType": "numeric",
          "text": "Developments in India (6th century BC-12th century ad)",
          "children": []
        },
        {
          "level": "4",
          "levelType": "numeric",
          "text": "Buddhism in Central Asia and China [see also 825. A.]",
          "children": []
        },
        {
          "level": "5",
          "levelType": "numeric",
          "text": "Buddhism in Korea and Japan [see also 825. D. and E.]",
          "children": []
        },
        {
          "level": "6",
          "levelType": "numeric",
          "text": "Buddhism in Tibet and the Himalayan kingdoms",
          "children": []
        },
        {
          "level": "7",
          "levelType": "numeric",
          "text": "Buddhism in Ceylon (Sri Lanka) and Southeast Asia to the mid- 19th century",
          "children": []
        },
        {
          "level": "8",
          "levelType": "numeric",
          "text": "Buddhism in the late 19th and 20th centuries",
          "children": []
        }
      ]
    },
    {
