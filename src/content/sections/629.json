{
  "sectionCode": "629",
  "sectionCodeDisplay": "629",
  "title": "The Decorative Arts and Functional Design",
  "outline": [
    {
      "level": "A",
      "levelType": "major",
      "text": "The nature and scope of the arts of decoration and functional design",
      "children": []
    },
    {
      "level": "B",
      "levelType": "major",
      "text": "The kinds of decorative arts and types of decorative objects classihed by the materials and methods used to produce or decorate them, or both",
      "children": [
        {
          "level": "1",
          "levelType": "numeric",
          "text": "Clay; e.g., earthenware, stoneware, porcelain",
          "children": []
        },
        {
          "level": "2",
          "levelType": "numeric",
          "text": "Fabrics",
          "children": []
        },
        {
          "level": "3",
          "levelType": "numeric",
          "text": "Gems",
          "children": []
        },
        {
          "level": "4",
          "levelType": "numeric",
          "text": "Glass",
          "children": []
        },
        {
          "level": "5",
          "levelType": "numeric",
          "text": "Metals",
          "children": []
        },
        {
          "level": "6",
          "levelType": "numeric",
          "text": "Paper; e.g., papier-mache, wallpaper",
          "children": []
        },
        {
          "level": "7",
          "levelType": "numeric",
          "text": "Stone",
          "children": []
        },
        {
          "level": "8",
          "levelType": "numeric",
          "text": "Wood",
          "children": []
        },
        {
          "level": "9",
          "levelType": "numeric",
          "text": "Other kinds of inorganic materials with special attention to",
          "children": [
            {
              "level": "a",
              "levelType": "lowercase",
              "text": "Plaster, cement, and concrete",
              "children": []
            },
            {
              "level": "b",
              "levelType": "lowercase",
              "text": "Plastics and other synthetic materials",
              "children": []
            }
          ]
        },
        {
          "level": "10",
          "levelType": "numeric",
          "text": "Other kinds of organic materials with special attention to",
          "children": [
            {
              "level": "a",
              "levelType": "lowercase",
              "text": "Flowers, foliage, and related botanical materials; e.g., bouquets, garlands, wreaths [for garden and landscape design, see 626.B.]",
              "children": []
            },
            {
              "level": "b",
              "levelType": "lowercase",
              "text": "Plant fibres, reeds, branches, and related materials; e.g., baskets, mats",
              "children": []
            },
            {
              "level": "c",
              "levelType": "lowercase",
              "text": "Skins, furs, and related materials",
              "children": []
            },
            {
              "level": "d",
              "levelType": "lowercase",
              "text": "Shell, horn, bone, ivory, and related materials",
              "children": []
            },
            {
              "level": "e",
              "levelType": "lowercase",
              "text": "Wax",
              "children": []
            }
          ]
        },
        {
          "level": "11",
          "levelType": "numeric",
          "text": "Special decorative finishing materials, processes, and techniques",
          "children": [
            {
              "level": "a",
              "levelType": "lowercase",
              "text": "Enamelwork; e.g., cloisonne, champleve, painted enamels",
              "children": []
            },
            {
              "level": "b",
              "levelType": "lowercase",
              "text": "Lacquerwork; e.g., carved lacquer, inlaid lacquer, laque burgaute",
              "children": []
            },
            {
              "level": "c",
              "levelType": "lowercase",
              "text": "Inlay work; e.g., veneering, intarsia, marquetry",
              "children": []
            }
          ]
        }
      ]
    },
    {
      "level": "C",
      "levelType": "major",
      "text": "The arts of functional design: kinds and types of artistic object classified by their function",
      "children": [
        {
          "level": "1",
          "levelType": "numeric",
          "text": "Dress design and body decoration",
          "children": [
            {
              "level": "a",
              "levelType": "lowercase",
              "text": "Dress and dress accessories [for the technological aspects of garment making, see 732.B.3.]",
              "children": []
            },
            {
              "level": "b",
              "levelType": "lowercase",
              "text": "Jewelry",
              "children": []
            },
            {
              "level": "c",
              "levelType": "lowercase",
              "text": "Body decoration: cosmetics; hairdressing and hair adornment; physical modification; perfumes, scents, and fragrances",
              "children": []
            }
          ]
        },
        {
          "level": "2",
          "levelType": "numeric",
          "text": "Industrial design",
          "children": [
            {
              "level": "a",
              "levelType": "lowercase",
              "text": "Industrial design as an art",
              "children": []
            },
            {
              "level": "b",
              "levelType": "lowercase",
              "text": "Diverse kinds of industrial design classified by function; e.g., design of commercial equipment, design of communications equipment, design of household appliances, design of transportation equipment",
              "children": []
            }
          ]
        },
        {
          "level": "3",
          "levelType": "numeric",
          "text": "Interior design",
          "children": [
            {
              "level": "a",
              "levelType": "lowercase",
              "text": "Interior design as an art",
              "children": []
            },
            {
              "level": "b",
              "levelType": "lowercase",
              "text": "The integration of interior design and decoration with architecture: the design and decoration of interior architectural elements",
              "children": [
                {
                  "level": "i",
                  "levelType": "lowercase",
                  "text": "Ceilings",
                  "children": []
                },
                {
                  "level": "ii",
                  "levelType": "roman",
                  "text": "Floors",
                  "children": []
                },
                {
                  "level": "iii",
                  "levelType": "roman",
                  "text": "Floor coverings; e.g., rugs, carpets, mats",
                  "children": []
                },
                {
                  "level": "iv",
                  "levelType": "roman",
                  "text": "Walls; e.g., molding, paneling, wallpaper",
                  "children": []
                }
              ]
            },
            {
              "level": "v",
              "levelType": "lowercase",
              "text": "Windows and doors",
              "children": [
                {
                  "level": "vi",
                  "levelType": "roman",
                  "text": "Other interior architectural elements; e.g., heating units, stairs and staircases",
                  "children": []
                }
              ]
            },
            {
              "level": "c",
              "levelType": "lowercase",
              "text": "Objects used for interior decoration: furniture and accessory furnishings [for technological aspects, see 732.B.4.]",
              "children": []
            }
          ]
        },
        {
          "level": "4",
          "levelType": "numeric",
          "text": "The design of materials and objects for communication and identification",
          "children": [
            {
              "level": "a",
              "levelType": "lowercase",
              "text": "Handwriting systems and styles: calligraphy, lettering, illuminating [for forms of writing, see 514.E.]",
              "children": []
            },
            {
              "level": "b",
              "levelType": "lowercase",
              "text": "Printing arts: typography and printing design, illustration, bookbinding [for printmaking, see 628. C.]",
              "children": []
            },
            {
              "level": "c",
              "levelType": "lowercase",
              "text": "Advertising art and design",
              "children": []
            },
            {
              "level": "d",
              "levelType": "lowercase",
              "text": "The design of signs and symbols used primarily for identification; e.g., heraldic design",
              "children": []
            },
            {
              "level": "e",
              "levelType": "lowercase",
              "text": "The design of exhibitions and displays; e.g., museum and gallery display",
              "children": []
            }
          ]
        },
        {
          "level": "5",
          "levelType": "numeric",
          "text": "The design and decoration of diverse kinds of specialized functional objects",
          "children": [
            {
              "level": "a",
              "levelType": "lowercase",
              "text": "The design of coins and currency and of medals",
              "children": []
            },
            {
              "level": "b",
              "levelType": "lowercase",
              "text": "The design and decoration of play materials",
              "children": []
            },
            {
              "level": "c",
              "levelType": "lowercase",
              "text": "Automata: the design of decorative mechanical objects",
              "children": []
            }
          ]
        }
      ]
    }
  ],
