            },
            {
              "level": "b",
              "levelType": "lowercase",
              "text": "Post-Vedic Sanskrit literature; e.g., epics, Puranas, Tantras",
              "children": []
            },
            {
              "level": "c",
              "levelType": "lowercase",
              "text": "Sacred literature in Indian regional languages",
              "children": []
            }
          ]
        },
        {
          "level": "2",
          "levelType": "numeric",
          "text": "Hindu mythology: varieties of myths, modes of representation and themes",
          "children": []
        },
        {
          "level": "3",
          "levelType": "numeric",
          "text": "Hindu philosophy: the integral relation of philosophy and religion in Hinduism",
          "children": []
        },
        {
          "level": "4",
          "levelType": "numeric",
          "text": "Hindu mysticism: its general characteristics, varieties, goals, and methods",
          "children": []
        }
