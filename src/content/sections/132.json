        },
        {
          "level": "2",
          "levelType": "numeric",
          "text": "Open clusters: systems containing about a dozen to hundreds of stars, usually in an unsymmetrical arrangement",
          "children": []
        },
        {
          "level": "3",
          "levelType": "numeric",
          "text": "Stellar associations: loose groupings containing dozens to a few hundred stars of similar spectral type and common origin",
          "children": []
