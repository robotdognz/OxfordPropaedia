    },
    {
      "level": "K",
      "levelType": "major",
      "text": "Electronic components and techniques used in communications",
      "children": [
        {
          "level": "1",
          "levelType": "numeric",
          "text": "Components",
          "children": [
            {
              "level": "a",
              "levelType": "lowercase",
              "text": "Active components: vacuum and gas-filled tubes, semiconductor devices",
              "children": []
            },
            {
              "level": "b",
              "levelType": "lowercase",
              "text": "Passive components: resistors, capacitors, and inductors; other solid-state devices; antennas and waveguides",
              "children": []
            },
            {
              "level": "c",
              "levelType": "lowercase",
              "text": "Integrated circuits: miniature arrays of interconnected active or passive circuit elements (e.g., microprocessors)",
              "children": []
            }
          ]
        },
        {
          "level": "2",
          "levelType": "numeric",
          "text": "Sensing devices and transducers; e.g., piezoelectric devices, photomultiplier tubes",
          "children": []
        }
