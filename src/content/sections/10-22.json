    {
      "level": "C",
      "levelType": "major",
      "text": "Geometry",
      "children": [
        {
          "level": "1",
          "levelType": "numeric",
          "text": "Euclidean geometry",
          "children": [
            {
              "level": "a",
              "levelType": "lowercase",
              "text": "Geometry as an abstract doctrine: the axiomatization of the foundations of geometry; axioms of order, incidence, congruence, parallels, and continuity and results derived from them",
              "children": []
            },
            {
              "level": "b",
              "levelType": "lowercase",
              "text": "The measure of polygons and polyhedra: the theories of equivalence and measure and their relation, Euclid's contribution and its modern extension and generalization",
              "children": []
            },
            {
              "level": "c",
              "levelType": "lowercase",
              "text": "Transformation geometry: reflection, rotation, and translation of geometric figures; homotheties and similitudes",
              "children": []
            },
            {
              "level": "d",
              "levelType": "lowercase",
              "text": "Geometric constructions: the equivalence between Euclidean constructions and existence theorems, gauge constructions, ruler and compass constructions, construction with compass only",
              "children": []
            },
            {
              "level": "e",
              "levelType": "lowercase",
              "text": "Geometry of more than three dimensions: the generalization of Euclidean geometry",
              "children": []
            },
            {
              "level": "f",
              "levelType": "lowercase",
              "text": "The concept of convexity and convex sets",
              "children": []
            }
          ]
        },
        {
          "level": "2",
          "levelType": "numeric",
          "text": "Non-Euclidean geometry [see also 10/21.B.l.b.)",
          "children": [
            {
              "level": "a",
              "levelType": "lowercase",
              "text": "Distinction between Euclidean and non-Euclidean geometry: hyperbolic geometry and elliptic geometry",
              "children": []
            },
            {
              "level": "b",
              "levelType": "lowercase",
              "text": "Geometric representations of the hyperbolic plane and hyperbolic space",
              "children": []
            },
            {
              "level": "c",
              "levelType": "lowercase",
              "text": "Coordinates in spherical and elliptical space: interpretations of four-dimensional Euclidean space",
              "children": []
            },
            {
              "level": "d",
              "levelType": "lowercase",
              "text": "Coordinates in the hyperbolic plane and hyperbolic trigonometry",
              "children": []
            },
            {
              "level": "e",
              "levelType": "lowercase",
              "text": "Transformations: hyperbolic geometry as characterized by its group of reflections",
              "children": []
            }
          ]
        },
        {
          "level": "3",
          "levelType": "numeric",
          "text": "Projective geometry",
          "children": [
            {
              "level": "a",
              "levelType": "lowercase",
              "text": "The procedure of projection as the foundation of projective geometry",
              "children": []
            },
            {
              "level": "b",
              "levelType": "lowercase",
              "text": "Homogeneous coordinates: location of points in space",
              "children": []
            },
            {
              "level": "c",
              "levelType": "lowercase",
              "text": "Complex geometry: introduction of complex numbers as homogeneous coordinates",
              "children": []
            },
            {
              "level": "d",
              "levelType": "lowercase",
              "text": "Abstract geometries: extension and generalization of projective geometry to space of any number of dimensions",
              "children": []
            }
          ]
        },
        {
          "level": "4",
          "levelType": "numeric",
          "text": "Analytic and trigonometric geometry",
          "children": [
            {
              "level": "a",
              "levelType": "lowercase",
              "text": "Plane analytic geometry: fundamental procedures and concepts",
              "children": []
            },
            {
              "level": "b",
              "levelType": "lowercase",
              "text": "Trigonometry",
              "children": []
            },
            {
              "level": "c",
              "levelType": "lowercase",
              "text": "Coordinates and transformation of coordinates",
              "children": []
            },
            {
              "level": "d",
              "levelType": "lowercase",
              "text": "Projective and solid analytic geometry: extensions of analytic geometry to the projective plane and to three or more dimensions",
              "children": []
            },
            {
              "level": "e",
              "levelType": "lowercase",
              "text": "Special curves: named curves that have been studied with regard to problems in mathematics or the physical sciences; e.g., the folium of Descartes, the lemniscate of Bernoulli, the cardioid, the cycloid, the catenary, the brachistochrone",
              "children": []
            }
          ]
        },
        {
          "level": "5",
          "levelType": "numeric",
          "text": "Combinatorial geometry [see E.l.c., below]",
          "children": []
        },
        {
          "level": "6",
          "levelType": "numeric",
          "text": "Differential geometry [see also F.2.e., below]",
          "children": []
        },
        {
          "level": "7",
          "levelType": "numeric",
          "text": "Algebraic geometry [see also F.3., below]",
          "children": []
        }
      ]
    },
