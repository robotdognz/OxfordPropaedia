            },
            {
              "level": "b",
              "levelType": "lowercase",
              "text": "The early electronic theory of bonding",
              "children": [
                {
                  "level": "i",
                  "levelType": "lowercase",
                  "text": "The nature of ionic bonds: shell theory, ion pairs",
                  "children": []
                },
                {
                  "level": "ii",
                  "levelType": "roman",
                  "text": "The nature of covalent and coordinate bonds: the octet",
                  "children": []
                }
              ]
            },
            {
              "level": "c",
              "levelType": "lowercase",
              "text": "Application of the quantum theory to atomic structure",
              "children": []
            }
          ]
        },
        {
          "level": "2",
          "levelType": "numeric",
          "text": "Quantum-mechanical treatment of chemical bonding",
          "children": [
            {
              "level": "a",
              "levelType": "lowercase",
              "text": "Atomic and molecular orbital concepts",
              "children": []
            },
            {
              "level": "b",
              "levelType": "lowercase",
              "text": "Bonding in the hydrogen molecule",
              "children": []
            },
            {
              "level": "c",
              "levelType": "lowercase",
              "text": "Bonding in simple polyatomic molecules",
              "children": []
            },
            {
              "level": "d",
              "levelType": "lowercase",
              "text": "Quantum-mechanical calculations",
              "children": []
            }
          ]
        },
        {
          "level": "3",
          "levelType": "numeric",
          "text": "Other bonding effects: hydrogen bonding; metallic bonds in metals, intermetallic compounds, and coordination compounds; bonds in crystals, in weak associations, and in electron-deficient compounds",
          "children": []
        },
        {
          "level": "4",
          "levelType": "numeric",
          "text": "Experimental observation of chemical bonding",
          "children": []
        },
        {
          "level": "5",
          "levelType": "numeric",
          "text": "Anomalous molecular structures, or molecular fragments with apparently anomalous valences: free radicals, carbenes, carbanions, carbonium ions",
          "children": []
        }
      ]
    },
    {
      "level": "E",
      "levelType": "major",
      "text": "Systems of classification of chemical compounds or substances",
      "children": [
        {
          "level": "1",
          "levelType": "numeric",
          "text": "By their elemental composition or molecular structure: organic, inorganic, organometallic, and nonstoichiometric compounds",
          "children": []
        },
        {
          "level": "2",
          "levelType": "numeric",
          "text": "By their bond type: ionic, covalent, and coordination compounds",
          "children": []
        },
        {
          "level": "3",
          "levelType": "numeric",
          "text": "By their chemical reactivity: acids, bases, and salts; oxidizing and reducing agents",
          "children": []
        },
        {
          "level": "4",
          "levelType": "numeric",
          "text": "By their physical state: gas, liquid, and solid",
          "children": []
        },
        {
          "level": "5",
          "levelType": "numeric",
          "text": "By their origin: natural and synthetic",
          "children": []
        }
