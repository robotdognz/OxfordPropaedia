{
  "sectionCode": "122",
  "sectionCodeDisplay": "122",
  "title": "Chemical Compounds: Molecular Structure and Chemical Bonding",
  "outline": [
    {
      "level": "A",
      "levelType": "major",
      "text": "The theory of molecular structure: its history and development",
      "children": [
        {
          "level": "1",
          "levelType": "numeric",
          "text": "Early concepts of molecular structure",
          "children": []
        },
        {
          "level": "2",
          "levelType": "numeric",
          "text": "Quantum mechanical and electrostatic approaches to the theory of molecular structure",
          "children": []
        },
        {
          "level": "3",
          "levelType": "numeric",
          "text": "Molecular bonds and shapes",
          "children": [
            {
              "level": "a",
              "levelType": "lowercase",
              "text": "Spatial arrangement of atoms: chains, rings, chelates, polymers",
              "children": []
            },
            {
              "level": "b",
              "levelType": "lowercase",
              "text": "Isomers: structural isomers, stereoisomers",
              "children": []
            }
          ]
        },
        {
          "level": "4",
          "levelType": "numeric",
          "text": "Time-dependency properties of molecules",
          "children": []
        },
        {
          "level": "5",
          "levelType": "numeric",
          "text": "Molecular structure and its relation to the properties of bulk matter",
          "children": [
            {
              "level": "a",
              "levelType": "lowercase",
              "text": "The physical properties of matter as affected by molecular size, shape, and interactions, and interactions of molecules with radiations and fields",
              "children": []
            },
            {
              "level": "b",
              "levelType": "lowercase",
              "text": "The chemical behaviour of matter as determined by the nature of molecular bonds",
              "children": []
            },
            {
              "level": "c",
              "levelType": "lowercase",
              "text": "The chemical, physical, and biochemical properties of a substance inferred from its known or postulated molecular structure",
              "children": []
            }
          ]
        }
      ]
    },
    {
      "level": "B",
      "levelType": "major",
      "text": "Experimental and theoretical procedures for the determination of molecular structures",
      "children": [
        {
          "level": "1",
          "levelType": "numeric",
          "text": "The separation, isolation, and purification of chemical substances based on chemical equilibria and rate phenomena",
          "children": [
            {
              "level": "a",
              "levelType": "lowercase",
              "text": "By volatility differences: distillation, sublimation, evaporization",
              "children": []
            },
            {
              "level": "b",
              "levelType": "lowercase",
              "text": "By chromatography: liquid phase, gas phase, thin layer",
              "children": []
            },
            {
              "level": "c",
              "levelType": "lowercase",
              "text": "By solubility differences: precipitation, crystallization, zone melting, solvent extraction",
              "children": []
            },
            {
              "level": "d",
              "levelType": "lowercase",
              "text": "By ion-exchange reactions",
              "children": []
            },
            {
              "level": "e",
              "levelType": "lowercase",
              "text": "By electrophoresis and electrolytic methods",
              "children": []
            },
            {
              "level": "f",
              "levelType": "lowercase",
              "text": "By mechanical methods: filtration, sedimentation, sieving, flotation, centrifugation",
              "children": []
            }
          ]
        },
        {
          "level": "2",
          "levelType": "numeric",
          "text": "Classical methods of qualitative and quantitative analysis",
          "children": []
        },
        {
          "level": "3",
          "levelType": "numeric",
          "text": "Instrumental methods used to identify functional groups, molecular sub-units, and structural features",
          "children": [
            {
              "level": "a",
              "levelType": "lowercase",
              "text": "Spectrochemical methods: microwave, infrared, ultraviolet, Raman spectroscopy, colorimetry, atomic absorption spectroscopy",
              "children": []
            },
            {
              "level": "b",
              "levelType": "lowercase",
              "text": "Mass spectrometry",
              "children": []
            },
            {
              "level": "c",
              "levelType": "lowercase",
              "text": "Magnetic resonance spectrometry",
              "children": []
            },
            {
              "level": "d",
              "levelType": "lowercase",
              "text": "Thermometric methods: thermogravimetry, calorimetry, cryoscopy",
              "children": []
            },
            {
              "level": "e",
              "levelType": "lowercase",
              "text": "Radiochemical methods: radiometric analysis, activation analysis, isotopic dilution",
              "children": []
            },
            {
              "level": "f",
              "levelType": "lowercase",
              "text": "Electrochemical methods: potentiometry, polarography, electrodeposition, oscillometry",
              "children": []
            }
          ]
        },
        {
          "level": "4",
          "levelType": "numeric",
          "text": "Diffraction methods for determining molecular structures: electron, X-ray, and neutron beam diffraction",
          "children": []
        },
        {
          "level": "5",
          "levelType": "numeric",
          "text": "Physical methods used to determine optical activity, magnetic susceptibility, calorific values, heat of combustion, activation energy, and reaction rates",
          "children": []
        },
        {
          "level": "6",
          "levelType": "numeric",
          "text": "The synthesis and characterization of derivatives, or specifically modified molecules",
          "children": []
        },
        {
          "level": "7",
          "levelType": "numeric",
          "text": "The determination of molecular weight based on thermodynamic theory, on transport phenomena, and on known spatial arrangements of atoms in the solid state",
          "children": []
        },
        {
          "level": "8",
          "levelType": "numeric",
          "text": "The principles of conformational analysis as related to molecular structure",
          "children": []
        },
        {
          "level": "9",
          "levelType": "numeric",
          "text": "The scattering of molecular beams and its usefulness in the study of molecular interactions",
          "children": []
        }
      ]
    },
    {
      "level": "C",
      "levelType": "major",
      "text": "Spectra of molecules",
      "children": [
        {
          "level": "1",
          "levelType": "numeric",
          "text": "The theory of molecular spectra",
          "children": []
        },
        {
          "level": "2",
          "levelType": "numeric",
          "text": "Types of molecular spectra: microwave, infrared, Raman, visible, and ultraviolet spectra",
          "children": []
        },
        {
          "level": "3",
          "levelType": "numeric",
          "text": "The interpretation of molecular band spectra in determining molecular structure",
          "children": []
        }
      ]
    },
    {
      "level": "D",
      "levelType": "major",
      "text": "The theory of chemical bonding: its development and experimental bases",
