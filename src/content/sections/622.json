{
  "sectionCode": "622",
  "sectionCodeDisplay": "622",
  "title": "Theatre",
  "outline": [
    {
      "level": "A",
      "levelType": "major",
      "text": "The art of theatre",
      "children": [
        {
          "level": "1",
          "levelType": "numeric",
          "text": "The nature and origins of theatre as an art",
          "children": []
        },
        {
          "level": "2",
          "levelType": "numeric",
          "text": "Functions of theatre and theatrical production; e.g., theatre as social, moral, or religious expression; theatre as entertainment",
          "children": []
        },
        {
          "level": "3",
          "levelType": "numeric",
          "text": "Problems of theatre and theatrical production",
          "children": []
        },
        {
          "level": "4",
          "levelType": "numeric",
          "text": "Interrelation of theatrical performance and audience",
          "children": []
        },
        {
          "level": "5",
          "levelType": "numeric",
          "text": "The arts of design in the theatre: staging and the design of stages, sets, lights, costumes, and makeup [see C.2., below]",
          "children": []
        },
        {
          "level": "6",
          "levelType": "numeric",
          "text": "Directing",
          "children": []
        },
        {
          "level": "7",
          "levelType": "numeric",
          "text": "Acting",
          "children": []
        },
        {
          "level": "8",
          "levelType": "numeric",
          "text": "The roles of other arts in the theatre: literature, music, dance, painting, and architecture [see C., below]",
          "children": []
        }
      ]
    },
    {
      "level": "B",
      "levelType": "major",
      "text": "Kinds and methods of theatrical production",
      "children": [
        {
          "level": "1",
          "levelType": "numeric",
          "text": "Diverse kinds of theatrical production",
          "children": [
            {
              "level": "a",
              "levelType": "lowercase",
              "text": "Kinds defined by the nature of the production itself",
              "children": [
                {
                  "level": "i",
                  "levelType": "lowercase",
                  "text": "The traditional dramatic forms or genres; e.g., tragedy, comedy [for these forms as literature, see 621.C.3.]",
                  "children": []
                },
                {
                  "level": "ii",
                  "levelType": "roman",
                  "text": "Dramatic improvisation: commedia dell'arte and related forms",
                  "children": []
                },
                {
                  "level": "iii",
                  "levelType": "roman",
                  "text": "Mime and pantomime",
                  "children": []
                },
                {
                  "level": "iv",
                  "levelType": "roman",
                  "text": "Puppet, marionette, and shadow plays and related forms",
                  "children": []
                }
              ]
            },
            {
              "level": "v",
              "levelType": "lowercase",
              "text": "Nondramatic theatrical production [see B.l.f., below]",
              "children": []
            },
            {
              "level": "b",
              "levelType": "lowercase",
              "text": "Kinds defined by their special purpose or audience; e.g., religious theatre, civic theatre, educational theatre, court theatre",
              "children": []
            },
            {
              "level": "c",
              "levelType": "lowercase",
              "text": "Kinds defined by their system of production; e.g., single-performance productions, repertory systems, stock companies, touring companies",
              "children": []
            },
            {
              "level": "d",
              "levelType": "lowercase",
              "text": "Kinds defined by the controlling artist; e.g., actor-dominated productions, dramatist-controlled productions, productions controlled by a nonperforming director",
              "children": []
            },
            {
              "level": "e",
              "levelType": "lowercase",
              "text": "Kinds defined by their style: general aesthetic style; styles of particular countries, historical periods, and playwrights",
              "children": []
            },
            {
              "level": "f",
              "levelType": "lowercase",
              "text": "Kinds defined by the lack of a unified dramatic structure",
              "children": [
                {
                  "level": "i",
                  "levelType": "lowercase",
                  "text": "Circuses and carnivals",
                  "children": []
                },
                {
                  "level": "ii",
                  "levelType": "roman",
                  "text": "Pageants, parades, and related forms",
                  "children": []
                },
                {
                  "level": "iii",
                  "levelType": "roman",
                  "text": "Popular entertainments: music hall, variety, and burlesque productions; nightclub shows; cabaret; musical comedy and revue",
                  "children": []
                }
              ]
            },
            {
              "level": "g",
              "levelType": "lowercase",
              "text": "Kinds defined by the cultural character of their audience: primitive, folk, and popular theatre",
              "children": []
            },
            {
              "level": "h",
              "levelType": "lowercase",
              "text": "Kinds defined by their production media: radio and television",
              "children": []
            }
          ]
        },
        {
          "level": "2",
          "levelType": "numeric",
          "text": "Methods of theatrical production",
          "children": []
        }
      ]
    },
    {
      "level": "C",
      "levelType": "major",
      "text": "Elements of theatrical production",
      "children": [
        {
          "level": "1",
          "levelType": "numeric",
          "text": "The production area: theatre buildings, stages, auditoriums",
          "children": [
            {
              "level": "a",
              "levelType": "lowercase",
              "text": "Theatre as place: kinds and uses of theatre buildings, stages, and auditoriums",
              "children": []
            },
            {
              "level": "b",
              "levelType": "lowercase",
              "text": "The historical development of theatres in Western and non-Western cultures",
              "children": []
            }
          ]
        },
        {
          "level": "2",
          "levelType": "numeric",
          "text": "Staging and stage design: the arrangement of words, dance, music, costumes, makeup, lighting, sound, and properties for theatrical effect",
          "children": []
        }
      ]
    },
    {
      "level": "D",
      "levelType": "major",
      "text": "The history of theatre",
      "children": [
        {
          "level": "1",
          "levelType": "numeric",
          "text": "Western theatre",
          "children": []
        }
      ]
    }
  ],
