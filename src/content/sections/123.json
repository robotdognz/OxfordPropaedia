  "title": "Chemical Reactions",
  "outline": [
    {
      "level": "A",
      "levelType": "major",
      "text": "General considerations of chemical reactions",
      "children": [
        {
          "level": "1",
          "levelType": "numeric",
          "text": "Basic concepts involved in the study of chemical reactions: transformation, conservation of mass and energy, law of simple multiple proportions in compounds",
          "children": []
        },
        {
          "level": "2",
          "levelType": "numeric",
          "text": "Growth of major theories concerning chemical reactions",
          "children": []
        },
        {
          "level": "3",
          "levelType": "numeric",
          "text": "Classification and nomenclature of the principal kinds of chemical reactions",
          "children": [
            {
              "level": "a",
              "levelType": "lowercase",
              "text": "According to the relationship involved between the starting materials and the final products",
              "children": [
                {
                  "level": "i",
                  "levelType": "lowercase",
                  "text": "Decomposition reactions",
                  "children": []
                },
                {
                  "level": "ii",
                  "levelType": "roman",
                  "text": "Polymerization reactions",
                  "children": []
                },
                {
                  "level": "iii",
                  "levelType": "roman",
                  "text": "Chain reactions",
                  "children": []
                },
                {
                  "level": "iv",
                  "levelType": "roman",
                  "text": "Substitution reactions",
                  "children": []
                }
              ]
            },
            {
              "level": "v",
              "levelType": "lowercase",
              "text": "Addition and elimination reactions",
              "children": [
                {
                  "level": "vi",
                  "levelType": "roman",
                  "text": "Oxidation-reduction reactions [see F., below]",
                  "children": []
                },
                {
                  "level": "vii",
                  "levelType": "roman",
                  "text": "Acid-base reactions [see E., below]",
                  "children": []
                }
              ]
            },
            {
              "level": "b",
              "levelType": "lowercase",
              "text": "According to the energy changes involved [see B.I., below]",
              "children": []
            },
            {
              "level": "c",
              "levelType": "lowercase",
              "text": "According to the reaction rates or chemical kinetics involved [see also C., below]",
              "children": []
            },
            {
              "level": "d",
              "levelType": "lowercase",
              "text": "According to the reaction mechanism involved [see D.4., below]",
              "children": []
            }
          ]
        }
      ]
    },
    {
