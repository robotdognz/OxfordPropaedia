        {
          "level": "1",
          "levelType": "numeric",
          "text": "Light as a wave motion: the wave theory of light",
          "children": [
            {
              "level": "a",
              "levelType": "lowercase",
              "text": "The properties of light consistent with the wave theory: diffraction, interference, polarization, dispersion",
              "children": []
            },
            {
              "level": "b",
              "levelType": "lowercase",
              "text": "The spectrum of light: the description of colour in terms of wavelengths",
