{
  "sectionCode": "128",
  "sectionCodeDisplay": "128",
  "title": "Waves and Wave Motion",
  "outline": [
    {
      "level": "A",
      "levelType": "major",
      "text": "General wave phenomena and the theory of wave motion",
      "children": [
        {
          "level": "1",
          "levelType": "numeric",
          "text": "General properties of waves: frequency, amplitude, wavelength, phase",
          "children": []
        },
        {
          "level": "2",
          "levelType": "numeric",
          "text": "Classification of waves",
          "children": [
            {
              "level": "a",
              "levelType": "lowercase",
              "text": "Waves classified by the medium supporting the transmission of wave motion: water waves, sound waves, electromagnetic waves",
              "children": []
            },
            {
              "level": "b",
              "levelType": "lowercase",
              "text": "Waves classified by the motion of particles in a wave: transverse, longitudinal, torsional, and cylindrical waves",
              "children": []
            },
            {
              "level": "c",
              "levelType": "lowercase",
              "text": "Other classifications: bow waves and shock waves",
              "children": []
            }
          ]
        },
        {
          "level": "3",
          "levelType": "numeric",
          "text": "The theory of waves",
          "children": [
            {
              "level": "a",
              "levelType": "lowercase",
              "text": "General characteristics of vibratory motion: periodicity, group velocity, energy content",
              "children": []
            },
            {
              "level": "b",
              "levelType": "lowercase",
              "text": "The velocity of waves",
              "children": []
            },
            {
              "level": "c",
              "levelType": "lowercase",
              "text": "The wave equation: the space-time description of wave motion",
              "children": []
            },
            {
              "level": "d",
              "levelType": "lowercase",
              "text": "Transport of energy and momentum",
              "children": []
            }
          ]
        },
        {
          "level": "4",
          "levelType": "numeric",
          "text": "The principle of superposition of waves",
          "children": [
            {
              "level": "a",
              "levelType": "lowercase",
              "text": "Standing waves: waves with stationary nodes",
              "children": []
            },
            {
              "level": "b",
              "levelType": "lowercase",
              "text": "Modulation of waves",
              "children": []
            },
            {
              "level": "c",
              "levelType": "lowercase",
              "text": "Pulse and wave trains",
              "children": []
            }
          ]
        },
        {
          "level": "5",
          "levelType": "numeric",
          "text": "The behaviour of waves at boundaries or interfaces: reflection, transmission, refraction",
          "children": []
        },
        {
          "level": "6",
          "levelType": "numeric",
          "text": "The diffraction and interference of waves",
          "children": []
        },
        {
          "level": "7",
          "levelType": "numeric",
          "text": "The interaction of waves with matter: absorption, dispersion",
          "children": []
        }
      ]
    },
    {
