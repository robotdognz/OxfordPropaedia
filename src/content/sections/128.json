        {
          "level": "3",
          "levelType": "numeric",
          "text": "Sources of incoherent electromagnetic waves",
          "children": [
            {
              "level": "a",
              "levelType": "lowercase",
              "text": "Sources of radio waves: oscillators, antennas, cosmic objects",
              "children": []
            },
            {
              "level": "b",
              "levelType": "lowercase",
              "text": "Sources of microwaves: klystrons, magnetrons, Gunn diodes, tunnel diodes, cosmic sources",
              "children": []
            },
            {
              "level": "c",
              "levelType": "lowercase",
              "text": "Sources of infrared, visible, and ultraviolet waves",
              "children": [
                {
                  "level": "i",
                  "levelType": "lowercase",
                  "text": "Blackbody radiation",
                  "children": []
                },
                {
                  "level": "ii",
                  "levelType": "roman",
                  "text": "Luminescence, fluorescence, phosphorescence",
                  "children": []
                },
                {
                  "level": "iii",
                  "levelType": "roman",
                  "text": "The passage of electrical current through a resisting medium",
                  "children": []
                }
              ]
            },
            {
              "level": "d",
              "levelType": "lowercase",
              "text": "Sources of X rays: X-ray tubes (bremsstrahlung), synchrotron radiation",
              "children": []
            },
            {
              "level": "e",
              "levelType": "lowercase",
              "text": "Sources of gamma rays: radioactive nuclei",
              "children": []
            }
          ]
        },
        {
          "level": "4",
          "levelType": "numeric",
          "text": "Sources of coherent electromagnetic waves: lasers and masers",
          "children": []
        },
        {
          "level": "5",
          "levelType": "numeric",
          "text": "The transmission of electromagnetic waves: through matter, through space, by wave guides and transmission lines",
          "children": []
        }
      ]
    },
    {
      "level": "C",
      "levelType": "major",
      "text": "Light waves",
