        },
        {
          "level": "9",
          "levelType": "numeric",
          "text": "The separation of light into its constituent wavelengths, the analysis of light spectra *",
          "children": []
        },
        {
          "level": "10",
          "levelType": "numeric",
          "text": "Sources of light",
          "children": []
        },
        {
          "level": "11",
          "levelType": "numeric",
          "text": "The biological effects of light, including photosynthesis [see 322.A. and 335.B.]",
          "children": []
        }
