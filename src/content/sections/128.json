          "level": "1",
          "levelType": "numeric",
          "text": "Properties and behaviour of electromagnetic waves",
          "children": []
        },
        {
          "level": "2",
          "levelType": "numeric",
          "text": "Waves of the electromagnetic spectrum and their properties",
          "children": [
            {
              "level": "a",
              "levelType": "lowercase",
              "text": "Radio waves",
              "children": []
            },
            {
              "level": "b",
              "levelType": "lowercase",
              "text": "Microwaves",
              "children": []
            },
            {
              "level": "c",
              "levelType": "lowercase",
              "text": "Infrared radiation",
              "children": []
            },
            {
              "level": "d",
              "levelType": "lowercase",
              "text": "Visible light [see C., below]",
              "children": []
            },
            {
              "level": "e",
              "levelType": "lowercase",
              "text": "Ultraviolet waves",
              "children": []
