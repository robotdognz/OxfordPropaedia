{
  "sectionCode": "971",
  "sectionCodeDisplay": "971",
  "title": "International Movements, Diplomacy, and War Since 1920",
  "outline": [
    {
      "level": "A",
      "levelType": "major",
      "text": "The period between the World Wars (1920-39)",
      "children": [
        {
          "level": "1",
          "levelType": "numeric",
          "text": "Immediate postwar problems (1920-24)",
          "children": [
            {
              "level": "a",
              "levelType": "lowercase",
              "text": "Failure of attempts to establish socialist and new democratic governments in Europe: dictatorships in the new nations of central and eastern Europe",
              "children": []
            },
            {
              "level": "b",
              "levelType": "lowercase",
              "text": "Diplomacy after the Paris Peace Conference (1919-20): establishment of the League of Nations; U.S., Soviet, and German diplomatic isolation; crises concerning enforcement of the peace settlement",
              "children": []
            }
          ]
        },
        {
          "level": "2",
          "levelType": "numeric",
          "text": "The temporary amelioration of international relations by the Locarno (1925) and Kellogg- Briand (1928) agreements, European recovery and the rapprochement with Germany",
          "children": []
        },
        {
          "level": "3",
          "levelType": "numeric",
          "text": "International affairs in the 1930s",
          "children": [
            {
              "level": "a",
              "levelType": "lowercase",
              "text": "The upsurge of strife in Asia: civil conflict in China and the Japanese seizure of Manchuria (1931-32), rise of the militarists in Japan and the Greater East Asia Co-prosperity Sphere",
              "children": []
            },
            {
              "level": "b",
              "levelType": "lowercase",
              "text": "The Popular Front and the Spanish Civil War (1936-39): unchecked Italian aggression against Ethiopia (1935-36), failure of the League of Nations and other diplomatic attempts (e.g the Munich agreement) to avert war",
              "children": []
            },
            {
              "level": "c",
              "levelType": "lowercase",
              "text": "The European colonial empires and client states: increased demands for self-determination among subject peoples, realignment of colonial powers",
              "children": []
            }
          ]
        },
        {
          "level": "4",
          "levelType": "numeric",
          "text": "Economic developments in the postwar period (1920-39)",
          "children": [
            {
              "level": "a",
              "levelType": "lowercase",
              "text": "Increased government control (1920-29): reconstruction, social welfare, and inflation",
              "children": []
            },
            {
              "level": "b",
              "levelType": "lowercase",
              "text": "Economic and political impact of the Great Depression of the 1930s: collapse of the world market and responses by various governments",
              "children": []
            },
            {
              "level": "c",
              "levelType": "lowercase",
              "text": "The establishment of Nazi Germany and economic recovery based on rearmament, Germany's alignment with Italy and Japan, the New Deal policy in the U.S., War Communism and the New Economic Policy in the Soviet Union",
              "children": []
            }
          ]
        }
      ]
    },
    {
      "level": "B",
      "levelType": "major",
      "text": "World Warll (1939-45)",
      "children": [
        {
          "level": "1",
          "levelType": "numeric",
          "text": "German conquest of Poland (1939) and France (1940); the German-Soviet Nonaggression Pact (1939) and subsequent German invasion of the Soviet Union (1941); the Battle of Britain (1940-41) and the war in North Africa (1940-43)",
          "children": []
        },
        {
          "level": "2",
          "levelType": "numeric",
          "text": "The war in Asia and the Pacific (1937-45)",
          "children": [
            {
              "level": "a",
              "levelType": "lowercase",
              "text": "Further Japanese aggression in China from 1937: the clash between U.S. and Japanese interests in the Pacific, the attack on Pearl Harbor (1941) and U.S. entry into the war",
              "children": []
            },
            {
              "level": "b",
              "levelType": "lowercase",
              "text": "Japanese conquests in the western Pacific and Southeast Asia (1941-42); the Allied counteroffensive from 1942 and Japanese defeat (1945)",
              "children": []
            }
          ]
        },
        {
          "level": "3",
          "levelType": "numeric",
          "text": "The war in Europe and North Africa (1942-45)",
          "children": [
            {
              "level": "a",
              "levelType": "lowercase",
              "text": "Beginning of U.S. active participation (1942), Allied progress against the Axis Powers in North Africa and Europe",
              "children": []
            },
            {
              "level": "b",
              "levelType": "lowercase",
              "text": "Collapse of the German Eastern Front (1944) and Soviet conquest of eastern Europe (1944- 45), Allied invasions of Italy (1943) and France (1944) and the defeat of Germany (1945)",
              "children": []
            }
          ]
        },
        {
          "level": "4",
          "levelType": "numeric",
          "text": "The leadership, industrial strength, strategic plans and goals, and tactical and logistical procedures of the Axis Powers",
          "children": []
        },
        {
          "level": "5",
          "levelType": "numeric",
          "text": "Allied wartime leadership and diplomacy: the Atlantic Charter; industrial strength, strategic plans and goals, and tactical and logistical procedures",
          "children": []
        },
        {
          "level": "6",
          "levelType": "numeric",
          "text": "The burgeoning of military technology; e.g., developments in communications devices, naval ' ships and aircraft, ground weapons and missiles, atomic bombs",
          "children": []
        }
      ]
    },
