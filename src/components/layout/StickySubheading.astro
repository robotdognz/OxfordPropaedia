---
interface BreadcrumbItem {
  label: string;
  mobileLabel?: string;
  compactLabel?: string;
  compactPriority?: number;
  href?: string;
}

interface ScrollTarget {
  id: string;
  label: string;
}

interface Props {
  breadcrumbs: BreadcrumbItem[];
  scrollTargets: ScrollTarget[];
  colorClass: string;
}

const { breadcrumbs, scrollTargets, colorClass } = Astro.props;
---

<div data-breadcrumbs-root class="sticky top-16 z-20 bg-white/95 backdrop-blur-sm border-b border-slate-200 font-sans">
  <div class="flex items-center justify-between gap-4 px-4 sm:px-8 py-2">
    <div
      data-breadcrumbs-scroll
      class="min-w-0 flex-1 overflow-x-auto [scrollbar-width:none] [-ms-overflow-style:none] [&::-webkit-scrollbar]:hidden"
    >
      <p class={`whitespace-nowrap text-[11px] sm:text-sm font-medium uppercase tracking-[0.14em] sm:tracking-wide ${colorClass}`}>
        {breadcrumbs.map((item, i) => (
          <>
            {i > 0 && <Fragment>&nbsp;&rsaquo;&nbsp;</Fragment>}
            {item.href
              ? (
                <a
                  href={item.href}
                  class="hover:underline"
                  data-breadcrumb-item
                  data-compact-priority={item.compactPriority ?? ''}
                >
                  <span data-breadcrumb-full>{item.label}</span>
                  <span data-breadcrumb-compact>{item.compactLabel ?? item.mobileLabel ?? item.label}</span>
                </a>
              )
              : (
                <span data-breadcrumb-item data-compact-priority={item.compactPriority ?? ''}>
                  <span data-breadcrumb-full>{item.label}</span>
                  <span data-breadcrumb-compact>{item.compactLabel ?? item.mobileLabel ?? item.label}</span>
                </span>
              )
            }
          </>
        ))}
      </p>
    </div>
    <div class="flex items-center gap-3 shrink-0 text-xs sm:text-sm font-medium">
      {scrollTargets.map((target) => (
        <button
          type="button"
          data-scroll-to={target.id}
          class="text-slate-500 hover:text-slate-800 transition-colors cursor-pointer"
        >
          {target.label}
        </button>
      ))}
    </div>
  </div>
</div>

<style>
  [data-breadcrumb-compact] {
    display: none;
  }

  [data-breadcrumbs-root][data-compact-stage] [data-breadcrumb-full] {
    display: inline;
  }

  [data-breadcrumbs-root][data-compact-stage="1"] [data-breadcrumb-item][data-compact-priority="1"] [data-breadcrumb-full],
  [data-breadcrumbs-root][data-compact-stage="2"] [data-breadcrumb-item][data-compact-priority="1"] [data-breadcrumb-full],
  [data-breadcrumbs-root][data-compact-stage="2"] [data-breadcrumb-item][data-compact-priority="2"] [data-breadcrumb-full],
  [data-breadcrumbs-root][data-compact-stage="3"] [data-breadcrumb-item][data-compact-priority="1"] [data-breadcrumb-full],
  [data-breadcrumbs-root][data-compact-stage="3"] [data-breadcrumb-item][data-compact-priority="2"] [data-breadcrumb-full],
  [data-breadcrumbs-root][data-compact-stage="3"] [data-breadcrumb-item][data-compact-priority="3"] [data-breadcrumb-full] {
    display: none;
  }

  [data-breadcrumbs-root][data-compact-stage="1"] [data-breadcrumb-item][data-compact-priority="1"] [data-breadcrumb-compact],
  [data-breadcrumbs-root][data-compact-stage="2"] [data-breadcrumb-item][data-compact-priority="1"] [data-breadcrumb-compact],
  [data-breadcrumbs-root][data-compact-stage="2"] [data-breadcrumb-item][data-compact-priority="2"] [data-breadcrumb-compact],
  [data-breadcrumbs-root][data-compact-stage="3"] [data-breadcrumb-item][data-compact-priority="1"] [data-breadcrumb-compact],
  [data-breadcrumbs-root][data-compact-stage="3"] [data-breadcrumb-item][data-compact-priority="2"] [data-breadcrumb-compact],
  [data-breadcrumbs-root][data-compact-stage="3"] [data-breadcrumb-item][data-compact-priority="3"] [data-breadcrumb-compact] {
    display: inline;
  }
</style>

<script is:inline>
  document.querySelectorAll('[data-breadcrumbs-root]').forEach(function(root) {
    var scrollEl = root.querySelector('[data-breadcrumbs-scroll]');
    if (!(scrollEl instanceof HTMLElement)) return;

    var mobileMedia = window.matchMedia('(max-width: 639px)');

    var priorities = Array.from(root.querySelectorAll('[data-breadcrumb-item][data-compact-priority]'))
      .map(function(el) {
        var raw = el.getAttribute('data-compact-priority');
        var value = raw ? Number(raw) : NaN;
        return Number.isFinite(value) ? value : 0;
      })
      .filter(function(value) { return value > 0; });

    var maxStage = priorities.length ? Math.max.apply(Math, priorities) : 0;

    function fitsAtStage(stage) {
      root.setAttribute('data-compact-stage', String(stage));
      return scrollEl.scrollWidth <= scrollEl.clientWidth + 4;
    }

    function updateCompactState() {
      if (!mobileMedia.matches) {
        root.setAttribute('data-compact-stage', '0');
        return;
      }

      for (var stage = 0; stage <= maxStage; stage += 1) {
        if (fitsAtStage(stage)) return;
      }

      root.setAttribute('data-compact-stage', String(maxStage));
    }

    var resizeObserver = new ResizeObserver(function() {
      requestAnimationFrame(updateCompactState);
    });

    resizeObserver.observe(scrollEl);
    resizeObserver.observe(root);
    mobileMedia.addEventListener('change', updateCompactState);
    requestAnimationFrame(updateCompactState);
  });

  document.querySelectorAll('[data-scroll-to]').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var target = document.getElementById(btn.getAttribute('data-scroll-to'));
      if (target) target.scrollIntoView({ behavior: 'smooth' });
    });
  });
</script>
