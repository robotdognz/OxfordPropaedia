---
import SidebarOutlineNav from './SidebarOutlineNav';

interface Props {
  currentPartNumber?: number;
  currentDivisionId?: string;
  currentSectionCode?: string;
}

const { currentPartNumber, currentDivisionId, currentSectionCode } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!-- Mobile overlay backdrop -->
<div id="sidebar-overlay" class="hidden fixed inset-0 z-30 bg-black/40 lg:hidden"></div>

<aside
  id="sidebar-nav"
  class="max-lg:hidden lg:block w-72 xl:w-80 flex-shrink-0 border-r border-gray-200 bg-gray-50
         lg:sticky lg:top-16 lg:h-[calc(100vh-4rem)] lg:pb-24 overflow-y-auto
         max-lg:fixed max-lg:top-16 max-lg:bottom-0 max-lg:left-0 max-lg:z-30 max-lg:pb-24 max-lg:shadow-xl"
>
  <!-- Site navigation links -->
  <nav aria-label="Site pages" class="px-3 pt-4 pb-2 font-sans text-sm border-b border-gray-200">
    <div class="space-y-0.5">
      <a href={`${base}/about`} class="block px-2 py-1.5 rounded-md text-gray-600 hover:bg-gray-100 hover:text-gray-900 transition-colors">Help</a>
    </div>
  </nav>

  <!-- Propaedia outline tree -->
  <SidebarOutlineNav
    client:load
    navUrl={`${base}/outline-nav.json`}
    currentPartNumber={currentPartNumber}
    currentDivisionId={currentDivisionId}
    currentSectionCode={currentSectionCode}
  />
</aside>
