---
import { partUrl, divisionUrl, sectionUrl } from '../../utils/helpers';
import ReadingPreferencePicker from '../content/ReadingPreferencePicker';

/**
 * Navigation tree types matching the data schema.
 */
export interface NavSection {
  sectionCode: string;
  sectionCodeDisplay?: string;
  title: string;
}

export interface NavDivision {
  divisionId: string;
  romanNumeral: string;
  title: string;
  sections: NavSection[];
}

export interface NavPart {
  partNumber: number;
  title: string;
  divisions: NavDivision[];
}

interface Props {
  navigation: NavPart[];
  currentPartNumber?: number;
  currentDivisionId?: string;
  currentSectionCode?: string;
}

const { navigation, currentPartNumber, currentDivisionId, currentSectionCode } = Astro.props;
const base = import.meta.env.BASE_URL;

// Build flat list of all section URLs for random navigation
const allSectionUrls: string[] = [];
for (const part of navigation) {
  for (const div of part.divisions) {
    for (const sec of div.sections) {
      allSectionUrls.push(sectionUrl(sec.sectionCode, base));
    }
  }
}

/**
 * Full Tailwind class maps -- spelled out so the JIT compiler detects them.
 */
const partTextColors: Record<number, string> = {
  1:  'text-part-1',
  2:  'text-part-2',
  3:  'text-part-3',
  4:  'text-part-4',
  5:  'text-part-5',
  6:  'text-part-6',
  7:  'text-part-7',
  8:  'text-part-8',
  9:  'text-part-9',
  10: 'text-part-10',
};

const partBgLightColors: Record<number, string> = {
  1:  'bg-part-1-light',
  2:  'bg-part-2-light',
  3:  'bg-part-3-light',
  4:  'bg-part-4-light',
  5:  'bg-part-5-light',
  6:  'bg-part-6-light',
  7:  'bg-part-7-light',
  8:  'bg-part-8-light',
  9:  'bg-part-9-light',
  10: 'bg-part-10-light',
};

const partBorderColors: Record<number, string> = {
  1:  'border-part-1',
  2:  'border-part-2',
  3:  'border-part-3',
  4:  'border-part-4',
  5:  'border-part-5',
  6:  'border-part-6',
  7:  'border-part-7',
  8:  'border-part-8',
  9:  'border-part-9',
  10: 'border-part-10',
};
---

<!-- Mobile overlay backdrop -->
<div id="sidebar-overlay" class="hidden fixed inset-0 z-30 bg-black/40 lg:hidden"></div>

<aside
  id="sidebar-nav"
  class="max-lg:hidden lg:block w-72 xl:w-80 flex-shrink-0 border-r border-gray-200 bg-gray-50
         lg:sticky lg:top-16 lg:h-[calc(100vh-4rem)] overflow-y-auto
         max-lg:fixed max-lg:top-16 max-lg:bottom-0 max-lg:left-0 max-lg:z-30 max-lg:shadow-xl"
>
  <!-- Site navigation links -->
  <nav aria-label="Site pages" class="px-3 pt-4 pb-2 font-sans text-sm border-b border-gray-200">
    <div class="space-y-0.5">
      <a href={`${base}/`} class="block px-2 py-1.5 rounded-md text-gray-600 hover:bg-gray-100 hover:text-gray-900 transition-colors font-medium">Home</a>
      <a href={`${base}/vsi`} class="block px-2 py-1.5 rounded-md text-gray-600 hover:bg-gray-100 hover:text-gray-900 transition-colors">Oxford VSI's</a>
      <a href={`${base}/wikipedia`} class="block px-2 py-1.5 rounded-md text-gray-600 hover:bg-gray-100 hover:text-gray-900 transition-colors">Wikipedia Articles</a>
      <a href={`${base}/iot`} class="block px-2 py-1.5 rounded-md text-gray-600 hover:bg-gray-100 hover:text-gray-900 transition-colors">BBC In Our Time</a>
      <a href={`${base}/macropaedia`} class="block px-2 py-1.5 rounded-md text-gray-600 hover:bg-gray-100 hover:text-gray-900 transition-colors">Britannica Articles</a>
      <a href={`${base}/about`} class="block px-2 py-1.5 rounded-md text-gray-600 hover:bg-gray-100 hover:text-gray-900 transition-colors">About</a>
    </div>
  </nav>

  <!-- Propaedia outline tree -->
  <nav aria-label="Knowledge outline" class="py-4 px-3 font-sans text-sm">
    {navigation.map((part) => {
      const isCurrentPart = part.partNumber === currentPartNumber;
      const textColor = partTextColors[part.partNumber] ?? 'text-gray-700';
      const bgLight = partBgLightColors[part.partNumber] ?? 'bg-gray-100';
      const borderColor = partBorderColors[part.partNumber] ?? 'border-gray-300';

      return (
        <details
          class="group mb-1"
          open={isCurrentPart}
        >
          {/* Part heading */}
          <summary
            class:list={[
              'flex items-center gap-2 px-2 py-2 rounded-md cursor-pointer select-none',
              'hover:bg-gray-100 transition-colors',
              'list-none [&::-webkit-details-marker]:hidden',
              isCurrentPart && bgLight,
            ]}
          >
            {/* Expand/collapse chevron */}
            <svg
              class="h-4 w-4 text-gray-400 flex-shrink-0 transition-transform group-open:rotate-90"
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>

            <a
              href={partUrl(part.partNumber, base)}
              class:list={[
                'font-semibold truncate',
                textColor,
              ]}
            >
              {part.title}
            </a>
          </summary>

          {/* Divisions */}
          <div class:list={['ml-4 pl-2 border-l-2 mt-1 mb-2', borderColor]}>
            {part.divisions.map((division) => {
              const isCurrentDivision = division.divisionId === currentDivisionId;
              const hasCurrent = isCurrentDivision || division.sections.some(s => s.sectionCode === currentSectionCode);

              return (
                <details class="group/div mb-1" open={hasCurrent}>
                  <summary
                    class:list={[
                      'flex items-center gap-1.5 px-2 py-1.5 rounded-md cursor-pointer select-none',
                      'hover:bg-gray-100 transition-colors',
                      'list-none [&::-webkit-details-marker]:hidden',
                      isCurrentDivision && 'bg-gray-100',
                    ]}
                  >
                    <svg
                      class="h-3 w-3 text-gray-300 flex-shrink-0 transition-transform group-open/div:rotate-90"
                      xmlns="http://www.w3.org/2000/svg"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                      stroke-width="2"
                    >
                      <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                    </svg>
                    <a
                      href={divisionUrl(division.divisionId, base)}
                      class:list={[
                        'truncate transition-colors',
                        isCurrentDivision
                          ? 'font-semibold text-gray-900'
                          : 'text-gray-600',
                      ]}
                    >
                      <span class="text-gray-400 mr-1">{division.romanNumeral}.</span>
                      {division.title}
                    </a>
                  </summary>

                  <div class="ml-4 mt-0.5 mb-1 space-y-0.5">
                    {division.sections.map((section) => {
                      const isCurrentSection = section.sectionCode === currentSectionCode;

                      return (
                        <a
                          href={sectionUrl(section.sectionCode, base)}
                          class:list={[
                            'block px-2 py-1 rounded text-xs transition-colors truncate',
                            'hover:bg-gray-100',
                            isCurrentSection
                              ? 'font-semibold text-gray-900 bg-gray-100'
                              : 'text-gray-500',
                          ]}
                        >
                          <span class="font-mono text-gray-400 mr-1">{section.sectionCodeDisplay ?? section.sectionCode}</span>
                          {section.title}
                        </a>
                      );
                    })}
                  </div>
                </details>
              );
            })}
          </div>
        </details>
      );
    })}
  </nav>

  <div class="px-3 py-3 border-t border-gray-200 font-sans">
    <p class="px-2 mb-1.5 text-[0.65rem] font-semibold uppercase tracking-wide text-slate-400">Preferred reading type</p>
    <ReadingPreferencePicker client:idle />
  </div>

  <div class="px-3 py-3 border-t border-gray-200 font-sans text-sm">
    <button
      type="button"
      id="random-section-btn"
      class="flex w-full items-center justify-center gap-2 rounded-md border border-slate-200 bg-white px-3 py-2 text-xs font-semibold text-slate-600 transition hover:bg-slate-50 hover:text-slate-900"
    >
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
      </svg>
      Random section
    </button>
  </div>

  <script is:inline define:vars={{ allSectionUrls }}>
    document.getElementById('random-section-btn')?.addEventListener('click', function () {
      var urls = allSectionUrls;
      if (urls.length > 0) {
        window.location.href = urls[Math.floor(Math.random() * urls.length)];
      }
    });
  </script>
</aside>
