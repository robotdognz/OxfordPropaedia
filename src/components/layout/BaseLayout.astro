---
import Header from './Header.astro';
import Sidebar from './Sidebar.astro';
import Footer from './Footer.astro';
import '../../styles/global.css';

interface Props {
  title: string;
  description?: string;
  currentPartNumber?: number;
  currentDivisionId?: string;
  currentSectionCode?: string;
}

const { title, description = 'Explore the Encyclopaedia Britannica Propaedia outline of human knowledge, paired with Oxford Very Short Introductions.', currentPartNumber, currentDivisionId, currentSectionCode } = Astro.props;
const base = import.meta.env.BASE_URL;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href={`${base}/icon.svg`} />
    <link rel="apple-touch-icon" href={`${base}/icon-192.png`} />
    <link rel="manifest" href={`${base}/manifest.json`} />
    <meta name="theme-color" content="#0f172a" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />

    <!-- Google Fonts: Inter for sans-serif headings and UI -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>
  </head>

  <body class="min-h-screen flex flex-col bg-white text-gray-900 antialiased">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-50 focus:px-4 focus:py-2 focus:bg-white focus:text-indigo-700 focus:rounded-md focus:shadow-lg focus:ring-2 focus:ring-indigo-400">
      Skip to main content
    </a>

    <Header searchEntriesUrl={`${base}/outline-search.json`} />

    <div class="flex-1 flex">
      <Sidebar
        currentPartNumber={currentPartNumber}
        currentDivisionId={currentDivisionId}
        currentSectionCode={currentSectionCode}
      />
      <div class="flex-1 min-w-0" data-pagefind-body>
        <slot />
      </div>
    </div>

    <Footer />

    <script is:inline>
      (function() {
        var EM_DASH = String.fromCharCode(8212);
        var SKIP_TAGS = /^(SCRIPT|STYLE|NOSCRIPT|TEXTAREA)$/;

        function normalizeDashText(value) {
          if (!value || (value.indexOf(EM_DASH) === -1 && value.indexOf('&mdash;') === -1)) {
            return value;
          }

          return value
            .replace(/\s*&mdash;\s*/g, ' - ')
            .replace(new RegExp('\\s*' + EM_DASH + '\\s*', 'g'), ' - ');
        }

        function normalizeTextNode(node) {
          if (!node || !node.nodeValue) return;
          var parent = node.parentNode;
          if (parent && parent.nodeType === Node.ELEMENT_NODE && SKIP_TAGS.test(parent.tagName)) {
            return;
          }

          var nextValue = normalizeDashText(node.nodeValue);
          if (nextValue !== node.nodeValue) {
            node.nodeValue = nextValue;
          }
        }

        function normalizeAttributes(element) {
          if (!(element instanceof HTMLElement)) return;

          ['title', 'aria-label', 'placeholder'].forEach(function(attributeName) {
            var currentValue = element.getAttribute(attributeName);
            if (!currentValue) return;

            var nextValue = normalizeDashText(currentValue);
            if (nextValue !== currentValue) {
              element.setAttribute(attributeName, nextValue);
            }
          });
        }

        function normalizeTree(root) {
          if (!root) return;

          if (root.nodeType === Node.TEXT_NODE) {
            normalizeTextNode(root);
            return;
          }

          if (root.nodeType !== Node.ELEMENT_NODE && root.nodeType !== Node.DOCUMENT_FRAGMENT_NODE) {
            return;
          }

          if (root.nodeType === Node.ELEMENT_NODE) {
            var elementRoot = root;
            if (SKIP_TAGS.test(elementRoot.tagName)) return;
            normalizeAttributes(elementRoot);
            elementRoot.querySelectorAll('[title],[aria-label],[placeholder]').forEach(normalizeAttributes);
          }

          var walker = document.createTreeWalker(root, NodeFilter.SHOW_TEXT);
          while (walker.nextNode()) {
            normalizeTextNode(walker.currentNode);
          }
        }

        document.title = normalizeDashText(document.title);
        normalizeTree(document.body);

        var observer = new MutationObserver(function(mutations) {
          mutations.forEach(function(mutation) {
            if (mutation.type === 'characterData') {
              normalizeTextNode(mutation.target);
            }

            mutation.addedNodes.forEach(normalizeTree);

            if (mutation.type === 'attributes' && mutation.target instanceof HTMLElement) {
              normalizeAttributes(mutation.target);
            }
          });
        });

        observer.observe(document.body, {
          subtree: true,
          childList: true,
          characterData: true,
          attributes: true,
          attributeFilter: ['title', 'aria-label', 'placeholder'],
        });
      })();
    </script>

    <script is:inline define:vars={{ swPath: `${base}/sw.js` }}>
      if ('serviceWorker' in navigator) {
        navigator.serviceWorker.register(swPath)
          .then((reg) => console.log('SW registered', reg.scope))
          .catch((err) => console.log('SW failed:', err));
      }
    </script>

    <script is:inline>
      (function() {
        var STORAGE_KEY = 'propaedia-cache-debug';
        var PARAM_KEY = 'cache-debug';
        var params = new URLSearchParams(window.location.search);
        var enabled = false;

        if (params.get(PARAM_KEY) === '1') {
          enabled = true;
          try {
            localStorage.setItem(STORAGE_KEY, '1');
          } catch (_error) {
            // Some browsers block localStorage in stricter privacy modes.
          }
        } else if (params.get(PARAM_KEY) === '0') {
          try {
            localStorage.removeItem(STORAGE_KEY);
          } catch (_error) {
            // Ignore storage failures and just disable for this page load.
          }
        } else {
          try {
            enabled = localStorage.getItem(STORAGE_KEY) === '1';
          } catch (_error) {
            enabled = false;
          }
        }

        if (!enabled) return;

        function truncateMiddle(value, maxLength) {
          if (!value || value.length <= maxLength) return value;
          var edgeLength = Math.max(8, Math.floor((maxLength - 1) / 2));
          return value.slice(0, edgeLength) + '…' + value.slice(-edgeLength);
        }

        function formatSource(source) {
          switch (source) {
            case 'full-site cache': return 'Full Snapshot';
            case 'full-site cache (fallback)': return 'Full Snapshot Fallback';
            case 'core cache': return 'Core Cache';
            case 'core cache (timeout)': return 'Core Cache Timeout';
            case 'core cache (fallback)': return 'Core Cache Fallback';
            case 'network': return 'Network';
            case 'home fallback': return 'Home Fallback';
            case 'error': return 'Error';
            default: return source || 'Waiting';
          }
        }

        function formatEntry(entry, fallbackText) {
          if (!entry) return fallbackText;
          var path = entry.path === '/' ? 'home' : entry.path;
          if (typeof entry.ms === 'number') {
            return [formatSource(entry.source), entry.ms + ' ms', truncateMiddle(path, 28)].join(' · ');
          }
          return [formatSource(entry.source), truncateMiddle(path, 32)].join(' · ');
        }

        function mountBadge() {
          if (!document.body || document.querySelector('[data-cache-debug-badge]')) return;

          var badge = document.createElement('aside');
          badge.setAttribute('aria-live', 'polite');
          badge.setAttribute('data-cache-debug-badge', '1');
          badge.style.cssText = [
            'position:fixed',
            'left:1rem',
            'bottom:1rem',
            'z-index:80',
            'width:min(22rem,calc(100vw - 2rem))',
            'border:1px solid rgba(148,163,184,0.6)',
            'background:rgba(255,255,255,0.96)',
            'backdrop-filter:blur(10px)',
            'border-radius:1rem',
            'box-shadow:0 18px 50px rgba(15,23,42,0.18)',
            'padding:0.85rem 0.9rem',
            'font:12px/1.45 Inter, sans-serif',
            'color:#0f172a'
          ].join(';');

          badge.innerHTML = [
            '<div style="display:flex;align-items:center;justify-content:space-between;gap:0.75rem;margin-bottom:0.5rem;">',
            '  <div>',
            '    <div style="font-size:11px;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:#64748b;">Cache Debug</div>',
            '    <div style="font-size:11px;color:#94a3b8;">Request source monitor</div>',
            '  </div>',
            '  <button type="button" data-cache-debug-hide style="border:0;background:transparent;color:#475569;font:inherit;cursor:pointer;padding:0;">Hide</button>',
            '</div>',
            '<div data-cache-debug-status style="font-size:11px;color:#64748b;margin-bottom:0.55rem;">Waiting for service worker…</div>',
            '<div style="display:grid;gap:0.35rem;">',
            '  <div data-cache-debug-page style="white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"></div>',
            '  <div data-cache-debug-data style="white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"></div>',
            '  <div data-cache-debug-asset style="white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"></div>',
            '</div>',
          ].join('');

          document.body.appendChild(badge);

          var statusEl = badge.querySelector('[data-cache-debug-status]');
          var pageEl = badge.querySelector('[data-cache-debug-page]');
          var dataEl = badge.querySelector('[data-cache-debug-data]');
          var assetEl = badge.querySelector('[data-cache-debug-asset]');
          var hideButton = badge.querySelector('[data-cache-debug-hide]');

          function renderState(state, statusText) {
            if (statusEl) {
              statusEl.textContent = statusText || 'Watching current page requests';
            }

            if (pageEl) {
              pageEl.textContent = 'Page: ' + formatEntry(state && state.page, 'Waiting');
            }
            if (dataEl) {
              dataEl.textContent = 'Data: ' + formatEntry(state && state.data, 'Waiting');
            }
            if (assetEl) {
              assetEl.textContent = 'Assets: ' + formatEntry(state && state.asset, 'Waiting');
            }
          }

          renderState(null, 'Waiting for service worker…');

          if (hideButton) {
            hideButton.addEventListener('click', function() {
              try {
                localStorage.removeItem(STORAGE_KEY);
              } catch (_error) {
                // Ignore storage failures and still hide the current badge.
              }
              badge.remove();
            });
          }

          function requestDebugState() {
            if (!('serviceWorker' in navigator)) {
              renderState(null, 'Service worker not available in this browser.');
              return;
            }

            if (!navigator.serviceWorker.controller) {
              renderState(null, 'No active controller yet. Reload once after updates.');
              return;
            }

            navigator.serviceWorker.controller.postMessage({
              type: 'propaedia-cache-debug-get',
            });
          }

          if (!('serviceWorker' in navigator)) {
            renderState(null, 'Service worker not available in this browser.');
            return;
          }

          navigator.serviceWorker.addEventListener('message', function(event) {
            if (!event.data || event.data.type !== 'propaedia-cache-debug-state') return;
            renderState(event.data.state || null);
          });

          navigator.serviceWorker.ready.then(function() {
            requestDebugState();
            window.setTimeout(requestDebugState, 500);
          });

          navigator.serviceWorker.addEventListener('controllerchange', function() {
            window.setTimeout(requestDebugState, 100);
          });
        }

        if (document.body) {
          mountBadge();
        } else {
          window.addEventListener('DOMContentLoaded', mountBadge, { once: true });
        }
      })();
    </script>

    <script is:inline>
      (function() {
        var HIGHLIGHT_CLASS = 'pagefind-highlight';
        var HIGHLIGHT_PARAM = 'pagefind-highlight';
        var terms = new URLSearchParams(window.location.search).getAll(HIGHLIGHT_PARAM);
        if (!terms.length) return;

        var escapedTerms = terms
          .filter(Boolean)
          .map(function(t) { return t.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'); });
        if (!escapedTerms.length) return;

        var termPattern = new RegExp(escapedTerms.join('|'), 'i');

        function delay(ms) {
          return new Promise(function(resolve) { setTimeout(resolve, ms); });
        }

        function waitForHydration() {
          return new Promise(function(resolve) {
            (function poll() {
              if (document.querySelectorAll('button[aria-expanded]').length) return resolve();
              setTimeout(poll, 50);
            })();
          });
        }

        /** Reads the accordion animation duration from the DOM (set by the Accordion component). */
        function getAnimationDelay() {
          var el = document.querySelector('[data-accordion-ms]');
          return (el ? parseInt(el.getAttribute('data-accordion-ms'), 10) : 300) + 50;
        }

        /** Opens accordions and <details> whose content matches the search terms. Returns count opened. */
        function openMatchingAccordions() {
          var main = document.querySelector('[data-pagefind-body]');
          if (!main) return 0;
          var count = 0;

          main.querySelectorAll('button[aria-expanded="false"]').forEach(function(btn) {
            var panelId = btn.getAttribute('aria-controls');
            var panel = panelId && document.getElementById(panelId);
            if (panel && termPattern.test(panel.textContent || '')) {
              btn.click();
              count++;
            }
          });

          main.querySelectorAll('details:not([open])').forEach(function(el) {
            if (termPattern.test(el.textContent || '')) {
              el.open = true;
              count++;
            }
          });

          return count;
        }

        /** Wraps visible text matches in <mark> elements. */
        function highlightMatches() {
          var regex = new RegExp('(' + escapedTerms.join('|') + ')', 'gi');
          var root = document.querySelector('[data-pagefind-body]') || document.body;
          var walker = document.createTreeWalker(root, NodeFilter.SHOW_TEXT);

          // Collect first - modifying the DOM during walk skips nodes
          var textNodes = [];
          while (walker.nextNode()) textNodes.push(walker.currentNode);

          textNodes.forEach(function(node) {
            if (!node.nodeValue || !regex.test(node.nodeValue)) return;
            regex.lastIndex = 0;
            var parent = node.parentNode;
            if (!parent) return;
            if (!parent.offsetParent && parent !== document.body) return; // not visible
            if (/^(SCRIPT|STYLE)$/.test(parent.tagName)) return;

            var frag = document.createDocumentFragment();
            var text = node.nodeValue;
            var last = 0;
            var m;
            while ((m = regex.exec(text))) {
              if (m.index > last) frag.appendChild(document.createTextNode(text.slice(last, m.index)));
              var mark = document.createElement('mark');
              mark.className = HIGHLIGHT_CLASS;
              mark.style.cssText = 'background:#fef08a;padding:1px 2px;border-radius:2px';
              mark.textContent = m[0];
              frag.appendChild(mark);
              last = regex.lastIndex;
            }
            if (last < text.length) frag.appendChild(document.createTextNode(text.slice(last)));
            parent.replaceChild(frag, node);
          });
        }

        /** Scrolls to the first visible highlight on the page. */
        function scrollToHighlight() {
          var target = document.querySelector('.' + HIGHLIGHT_CLASS);
          if (target) target.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }

        async function run() {
          await waitForHydration();
          var animDelay = getAnimationDelay();

          // Pass 1: open parent accordions containing the search term
          var opened = openMatchingAccordions();
          if (opened > 0) {
            await delay(animDelay);
            // Pass 2: open nested accordions now visible inside opened parents
            openMatchingAccordions();
            await delay(animDelay);
          }

          highlightMatches();
          await delay(animDelay); // wait for overflow:visible transition
          scrollToHighlight();
        }

        run();
      })();
    </script>
  </body>
</html>
