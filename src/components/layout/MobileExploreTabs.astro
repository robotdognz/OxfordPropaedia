---
import { roundedDonutSlicePath } from '../../utils/donutPaths';

const base = import.meta.env.BASE_URL;

const ICON_SIZE = 24;
const ICON_CENTER = ICON_SIZE / 2;
const ICON_OUTER_RADIUS = 9.15;
const ICON_INNER_RADIUS = 5.1;
const ICON_GAP_PX = 0.82;
const ICON_CORNER_RADIUS_PX = 1.25;
const TAB_ICON_CLASS = 'h-[1.48rem] w-[1.48rem]';
const GLOBAL_ICON_ROTATION_DEG = -30;

type WedgeIconSegment = {
  startDeg: number;
  endDeg: number;
  fillOpacity?: number;
  innerRadius?: number;
  outerRadius?: number;
  stroke?: boolean;
};

function buildWedgeIconSegments(segments: WedgeIconSegment[]) {
  return segments
    .map((segment) => ({
      ...segment,
      path: roundedDonutSlicePath(
        ICON_CENTER,
        ICON_CENTER,
        segment.innerRadius ?? ICON_INNER_RADIUS,
        segment.outerRadius ?? ICON_OUTER_RADIUS,
        segment.startDeg,
        segment.endDeg,
        {
          gapPx: ICON_GAP_PX,
          cornerRadiusPx: ICON_CORNER_RADIUS_PX,
        },
      ),
    }))
    .filter((segment) => Boolean(segment.path));
}

const globalIconSegments = buildWedgeIconSegments(
  Array.from({ length: 6 }, (_, index) => ({
    startDeg: index * 60,
    endDeg: (index + 1) * 60,
    fillOpacity: 0.94,
  })),
);

const tabs = [
  { workspace: 'whole-outline', label: 'Everything' },
  { workspace: 'selected-fields', label: 'Guided' },
  { workspace: 'specific-topic', label: 'Outline' },
  { workspace: 'library', label: 'Library' },
] as const;

const workspaceHrefs = {
  'whole-outline': `${base}/?explore=whole-outline`,
  'selected-fields': `${base}/?explore=selected-fields`,
  'specific-topic': `${base}/?explore=specific-topic`,
  'library': `${base}/library`,
};
---

<div data-pagefind-ignore>
  <nav
    id="mobile-explore-tabs"
    aria-label="Explore Propaedia"
    class="fixed inset-x-0 bottom-0 z-20 border-t border-slate-200 bg-white/95 backdrop-blur"
    style="padding-bottom: max(env(safe-area-inset-bottom), 0.25rem);"
  >
    <div class="mx-auto grid max-w-screen-lg grid-cols-4 gap-1 px-2 pb-1.5 pt-1.5 lg:max-w-2xl">
      {tabs.map((tab) => (
        <a
          data-mobile-workspace-tab={tab.workspace}
          href={workspaceHrefs[tab.workspace]}
          class="relative flex min-w-0 flex-col items-center rounded-xl px-2 py-1.5 text-[0.66rem] font-sans font-medium text-slate-500 transition-colors duration-200"
        >
          <span
            data-mobile-workspace-content
            class="relative z-10 flex flex-col items-center gap-0.5 transition-transform duration-200"
          >
            <span
              data-mobile-workspace-icon
              class="flex h-8 w-11 items-center justify-center rounded-lg text-slate-400 transition-colors duration-200"
              aria-hidden="true"
            >
              {tab.workspace === 'whole-outline' ? (
                <svg class={TAB_ICON_CLASS} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                  <circle cx="12" cy="12" r="7.65"></circle>
                  <circle cx="12" cy="12" r="3.55"></circle>
                </svg>
              ) : tab.workspace === 'selected-fields' ? (
                <svg class={TAB_ICON_CLASS} viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <g transform={`rotate(${GLOBAL_ICON_ROTATION_DEG} ${ICON_CENTER} ${ICON_CENTER})`}>
                    {globalIconSegments.map((segment) => (
                      <path d={segment.path} fill="currentColor" fill-opacity={segment.fillOpacity ?? 0.94} />
                    ))}
                  </g>
                </svg>
              ) : tab.workspace === 'specific-topic' ? (
                <svg class={TAB_ICON_CLASS} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                  <path d="M6.8 5.7h10.4"></path>
                  <path d="M6.8 12h7.5"></path>
                  <path d="M6.8 18.3h5.4"></path>
                  <circle cx="5.6" cy="5.7" r="1"></circle>
                  <circle cx="5.6" cy="12" r="1"></circle>
                  <circle cx="5.6" cy="18.3" r="1"></circle>
                </svg>
              ) : (
                <svg
                  class={TAB_ICON_CLASS}
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.8"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M12 6.1a8.85 8.85 0 0 0-5.95-2.35c-1.03 0-2.02.18-2.8.52v13.42a8.8 8.8 0 0 1 2.8-.44c2.3 0 4.44.85 5.95 2.25"></path>
                  <path d="M12 6.1a8.85 8.85 0 0 1 5.95-2.35c1.03 0 2.02.18 2.8.52v13.42a8.8 8.8 0 0 0-2.8-.44c-2.3 0-4.44.85-5.95 2.25"></path>
                  <path d="M12 6.1v13.4"></path>
                </svg>
              )}
            </span>
            <span
              data-mobile-workspace-label
              class="truncate text-center leading-tight transition-[color,transform] duration-200"
            >
              {tab.label}
            </span>
          </span>
        </a>
      ))}
    </div>
  </nav>
</div>

<style is:inline>
  [data-mobile-workspace-tab][data-active='true'] {
    color: #0f172a;
  }

  [data-mobile-workspace-tab][data-active='true'] [data-mobile-workspace-icon] {
    color: #0f172a;
  }

  [data-mobile-workspace-tab][data-active='true'] [data-mobile-workspace-icon] svg {
    filter:
      drop-shadow(0 6px 8px rgb(15 23 42 / 0.22))
      drop-shadow(0 2px 3px rgb(15 23 42 / 0.14));
  }

  [data-mobile-workspace-tab][data-active='true'] [data-mobile-workspace-label] {
    text-shadow:
      0 5px 8px rgb(15 23 42 / 0.2),
      0 2px 3px rgb(15 23 42 / 0.12);
  }

  [data-mobile-workspace-tab][data-active='true'] [data-mobile-workspace-content] {
    transform: translateY(-1px);
  }
</style>

  <script
  is:inline
  define:vars={{
    workspaceHrefs,
    activeWorkspaceStorageKey: 'propaedia-active-workspace',
    workspaceUrlsStorageKey: 'propaedia-workspace-urls-v1',
  }}
>
  (() => {
    const WORKSPACES = ['whole-outline', 'selected-fields', 'specific-topic', 'library'];
    const HOME_WORKSPACES = ['whole-outline', 'selected-fields', 'specific-topic'];
    const tabs = Array.from(document.querySelectorAll('[data-mobile-workspace-tab]'));
    if (!tabs.length) return;

    const normalizePath = (pathname) => (pathname && pathname !== '/' ? pathname.replace(/\/$/, '') : pathname || '/');
    const homePath = normalizePath(new URL(workspaceHrefs['whole-outline'], window.location.origin).pathname);
    const libraryPath = normalizePath(new URL(workspaceHrefs['library'], window.location.origin).pathname);
    const currentUrlKey = () => `${window.location.pathname}${window.location.search}`;
    const homeUrlKey = (workspace) => {
      const url = new URL(workspaceHrefs[workspace], window.location.origin);
      return `${url.pathname}${url.search}`;
    };
    const basePrefix = homePath === '/' ? '' : homePath;
    const librarySourceRoots = [
      `${basePrefix}/vsi`,
      `${basePrefix}/wikipedia`,
      `${basePrefix}/iot`,
      `${basePrefix}/macropaedia`,
    ];

    function isSpecificTopicRoute(pathname) {
      const normalized = normalizePath(pathname);
      return (
        normalized.startsWith(`${basePrefix}/part/`) ||
        normalized.startsWith(`${basePrefix}/division/`) ||
        normalized.startsWith(`${basePrefix}/section/`)
      );
    }

    function isLibraryRoute(pathname) {
      const normalized = normalizePath(pathname);
      return (
        normalized === libraryPath ||
        librarySourceRoots.some((root) => normalized === root || normalized.startsWith(root + '/'))
      );
    }

    function readStoredWorkspace() {
      try {
        const value = window.localStorage.getItem(activeWorkspaceStorageKey);
        return WORKSPACES.includes(value) ? value : null;
      } catch {
        return null;
      }
    }

    function writeStoredWorkspace(workspace) {
      try {
        window.localStorage.setItem(activeWorkspaceStorageKey, workspace);
      } catch {
        // Ignore storage failures and keep the tabs interactive.
      }
    }

    function readStoredWorkspaceUrls() {
      try {
        const raw = window.localStorage.getItem(workspaceUrlsStorageKey);
        if (!raw) return {};
        const parsed = JSON.parse(raw);
        return parsed && typeof parsed === 'object' ? parsed : {};
      } catch {
        return {};
      }
    }

    function writeStoredWorkspaceUrls(urls) {
      try {
        window.localStorage.setItem(workspaceUrlsStorageKey, JSON.stringify(urls));
      } catch {
        // Ignore storage failures and keep the tabs interactive.
      }
    }

    function detectWorkspace() {
      const pathname = normalizePath(window.location.pathname);

      if (pathname === homePath) {
        const current = new URL(window.location.href);
        const requested = current.searchParams.get('explore');
        if (HOME_WORKSPACES.includes(requested)) return requested;

        const stored = readStoredWorkspace();
        return HOME_WORKSPACES.includes(stored) ? stored : 'whole-outline';
      }

      if (isLibraryRoute(pathname)) {
        return 'library';
      }

      if (isSpecificTopicRoute(pathname)) {
        return 'specific-topic';
      }

      return readStoredWorkspace() ?? 'whole-outline';
    }

    function syncStoredUrls() {
      const urls = readStoredWorkspaceUrls();
      const pathname = normalizePath(window.location.pathname);
      const current = new URL(window.location.href);
      const requestedHomeWorkspace = pathname === homePath ? current.searchParams.get('explore') : null;
      urls['whole-outline'] = homeUrlKey('whole-outline');
      urls['selected-fields'] = homeUrlKey('selected-fields');
      if (isLibraryRoute(window.location.pathname)) {
        urls['library'] = currentUrlKey();
      } else if (!urls['library']) {
        urls['library'] = homeUrlKey('library');
      }

      if (isSpecificTopicRoute(window.location.pathname) || requestedHomeWorkspace === 'specific-topic') {
        urls['specific-topic'] = currentUrlKey();
      } else if (!urls['specific-topic']) {
        urls['specific-topic'] = homeUrlKey('specific-topic');
      }

      writeStoredWorkspaceUrls(urls);
      return urls;
    }

    function syncTabs() {
      const workspace = detectWorkspace();
      const urls = syncStoredUrls();
      writeStoredWorkspace(workspace);

      tabs.forEach((tab) => {
        if (!(tab instanceof HTMLAnchorElement)) return;
        const tabWorkspace = tab.getAttribute('data-mobile-workspace-tab');
        if (!tabWorkspace || !WORKSPACES.includes(tabWorkspace)) return;

        const isCurrentWorkspaceRoute =
          tabWorkspace === workspace && (
            normalizePath(window.location.pathname) === homePath ||
            (tabWorkspace === 'specific-topic' && isSpecificTopicRoute(window.location.pathname)) ||
            (tabWorkspace === 'library' && isLibraryRoute(window.location.pathname))
          );
        const href = isCurrentWorkspaceRoute
          ? currentUrlKey()
          : (urls[tabWorkspace] || homeUrlKey(tabWorkspace));
        tab.href = href;
        tab.dataset.active = tabWorkspace === workspace ? 'true' : 'false';
      });
    }

    tabs.forEach((tab) => {
      if (!(tab instanceof HTMLAnchorElement)) return;

      tab.addEventListener('click', (event) => {
        const workspace = tab.getAttribute('data-mobile-workspace-tab');
        if (!workspace || !WORKSPACES.includes(workspace)) return;

        writeStoredWorkspace(workspace);

        const targetUrl = new URL(tab.href, window.location.origin);
        const targetUrlKey = `${targetUrl.pathname}${targetUrl.search}`;
        const currentWorkspace = detectWorkspace();

        if (targetUrlKey === currentUrlKey()) {
          event.preventDefault();
          syncTabs();
          return;
        }

        if (normalizePath(window.location.pathname) === homePath && normalizePath(targetUrl.pathname) === homePath) {
          event.preventDefault();

          document.dispatchEvent(
            new CustomEvent('propaedia:workspace-before-change', {
              detail: {
                workspace: currentWorkspace,
                urlKey: currentUrlKey(),
              },
            }),
          );

          history.pushState(null, '', targetUrlKey);

          document.dispatchEvent(
            new CustomEvent('propaedia:workspace-change', {
              detail: {
                workspace,
                urlKey: targetUrlKey,
              },
            }),
          );

          syncTabs();

          document.dispatchEvent(
            new CustomEvent('propaedia:workspace-after-change', {
              detail: {
                workspace,
                urlKey: targetUrlKey,
              },
            }),
          );
        }
      });
    });

    window.addEventListener('popstate', syncTabs);
    document.addEventListener('propaedia:workspace-change', syncTabs);
    syncTabs();
  })();
</script>
