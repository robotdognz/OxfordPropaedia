---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import NotesDisclosure from '../../components/content/NotesDisclosure.astro';
import TopReadings from '../../components/content/TopReadings';
import navigation from '../../data/navigation.json';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const parts = await getCollection('parts');
  const essays = await getCollection('essays');
  return parts.map((part) => {
    const essay = essays.find((e) => e.data.partNumber === part.data.partNumber);
    return {
      params: { partNumber: String(part.data.partNumber) },
      props: { part: part.data, essay },
    };
  });
}

const { part, essay } = Astro.props;
let EssayContent: any = null;
if (essay) {
  const { Content } = await render(essay);
  EssayContent = Content;
}
const base = import.meta.env.BASE_URL;

const PART_NAMES: Record<number, string> = {
  1: 'One', 2: 'Two', 3: 'Three', 4: 'Four', 5: 'Five',
  6: 'Six', 7: 'Seven', 8: 'Eight', 9: 'Nine', 10: 'Ten',
};

const partNav = navigation.parts.find((p) => p.partNumber === part.partNumber);
const divisions = partNav?.divisions ?? [];

// Load reading recommendations for this part
const allPartReadings = await getCollection('part-readings');
const partReadingsEntry = allPartReadings.find((r) => r.data.partNumber === part.partNumber);
const partReadings = partReadingsEntry?.data.readings;

// Prev/next parts
const partIndex = navigation.parts.findIndex((p) => p.partNumber === part.partNumber);
const prevPart = partIndex > 0 ? navigation.parts[partIndex - 1] : null;
const nextPart = partIndex < navigation.parts.length - 1 ? navigation.parts[partIndex + 1] : null;

const partColors: Record<number, string> = {
  1: 'text-blue-800 border-blue-300',
  2: 'text-emerald-800 border-emerald-300',
  3: 'text-green-700 border-green-300',
  4: 'text-red-700 border-red-300',
  5: 'text-violet-700 border-violet-300',
  6: 'text-orange-700 border-orange-300',
  7: 'text-cyan-700 border-cyan-300',
  8: 'text-indigo-700 border-indigo-300',
  9: 'text-pink-700 border-pink-300',
  10: 'text-amber-700 border-amber-300',
};

const bgColors: Record<number, string> = {
  1: 'bg-blue-800',
  2: 'bg-emerald-800',
  3: 'bg-green-600',
  4: 'bg-red-600',
  5: 'bg-violet-700',
  6: 'bg-orange-600',
  7: 'bg-cyan-700',
  8: 'bg-indigo-700',
  9: 'bg-pink-700',
  10: 'bg-amber-700',
};

---

<BaseLayout title={`Part ${PART_NAMES[part.partNumber]}: ${part.title} — Propaedia`} currentPartNumber={part.partNumber}>
    <main id="main-content" class="flex-1 min-w-0 px-4 sm:px-8 py-6">

      <header class="mb-10">
        <div class="flex items-center gap-3 mb-2">
          <span class={`inline-flex items-center justify-center w-10 h-10 rounded-full font-sans text-white font-bold leading-none ${bgColors[part.partNumber]}`}>
            {part.partNumber}
          </span>
          <span class="text-sm font-sans font-medium text-gray-500 uppercase tracking-wide">
            Part {PART_NAMES[part.partNumber]}
          </span>
        </div>
        <h1 class="text-4xl font-serif font-bold text-gray-900 mb-2" data-pagefind-meta={`title:Part ${PART_NAMES[part.partNumber]}: ${part.title}`}>
          {part.title}
        </h1>
        <span data-pagefind-meta="page_type:Part" class="hidden"></span>
        {part.subtitle && (
          <p class="text-lg text-gray-600">{part.subtitle}</p>
        )}
      </header>

      <!-- Introductory Essay -->
      {EssayContent && (
        <section class="mb-10">
          <details class="group">
            <summary class="cursor-pointer text-lg font-sans font-semibold text-gray-700 flex items-center gap-2">
              <svg class="w-5 h-5 transition-transform group-open:rotate-90" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
              Introductory Essay
              {essay?.data.author && (
                <span class="text-sm font-normal text-gray-500">by {essay.data.author}</span>
              )}
            </summary>
            <div class="mt-4 pl-7 prose-propaedia">
              <EssayContent />
            </div>
          </details>
        </section>
      )}

      <NotesDisclosure
        paragraphs={part.headnote ?? []}
        baseUrl={base}
        currentHref={`${base}/part/${part.partNumber}`}
      />

      <!-- Divisions List -->
      <section>
        <h2 class="text-2xl font-sans font-bold text-gray-800 mb-6">Divisions</h2>
        <div class="space-y-4">
          {divisions.map((div) => (
            <a href={`${base}/division/${div.divisionId}`}
              class={`block rounded-lg border-2 p-5 transition-all hover:shadow-md ${partColors[part.partNumber]}`}>
              <div class="flex items-center gap-3 mb-2">
                <span class="font-mono text-sm font-semibold text-gray-500">
                  Division {div.romanNumeral}
                </span>
              </div>
              <h3 class="text-xl font-serif font-bold">
                {div.title}
              </h3>
              {div.sections.length > 0 && (
                <p class="text-sm text-gray-500 mt-2">
                  {div.sections.length} {div.sections.length === 1 ? 'section' : 'sections'}
                </p>
              )}
            </a>
          ))}
        </div>
      </section>

      {partReadings && (
        <section class="mt-10">
          <TopReadings
            client:load
            vsi={partReadings.vsi}
            wiki={partReadings.wiki}
            macro={partReadings.macro}
            baseUrl={base}
            contextLabel="this part"
            countLabel="divisions"
          />
        </section>
      )}

      {(prevPart || nextPart) && (
        <nav class="mt-12 flex items-stretch gap-3 border-t border-slate-200 pt-6" aria-label="Part navigation">
          {prevPart ? (
            <a
              href={`${base}/part/${prevPart.partNumber}`}
              class="group flex min-w-0 flex-1 items-center gap-2 rounded-xl border border-slate-200 px-4 py-3 transition hover:border-slate-300 hover:bg-slate-50"
            >
              <svg class="h-4 w-4 shrink-0 text-slate-400 group-hover:text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
              </svg>
              <div class="min-w-0">
                <p class="text-xs font-sans font-semibold uppercase tracking-wide text-slate-400">Previous</p>
                <p class="truncate text-sm font-serif font-semibold text-slate-700 group-hover:text-slate-900">{prevPart.title}</p>
              </div>
            </a>
          ) : <div class="flex-1" />}
          {nextPart ? (
            <a
              href={`${base}/part/${nextPart.partNumber}`}
              class="group flex min-w-0 flex-1 items-center justify-end gap-2 rounded-xl border border-slate-200 px-4 py-3 text-right transition hover:border-slate-300 hover:bg-slate-50"
            >
              <div class="min-w-0">
                <p class="text-xs font-sans font-semibold uppercase tracking-wide text-slate-400">Next</p>
                <p class="truncate text-sm font-serif font-semibold text-slate-700 group-hover:text-slate-900">{nextPart.title}</p>
              </div>
              <svg class="h-4 w-4 shrink-0 text-slate-400 group-hover:text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          ) : <div class="flex-1" />}
        </nav>
      )}
    </main>
</BaseLayout>
