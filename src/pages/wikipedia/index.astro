---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import WikipediaLibrary from '../../components/content/WikipediaLibrary';
import { buildWikipediaAggregateEntries, type ReadingSectionSummary } from '../../utils/readingData';
import wikiCatalog from '../../data/wikipedia-catalog.json';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL;
const sections = await getCollection('sections');
const wikiMappings = await getCollection('wiki-mappings');

const sectionLookup = new Map<string, ReadingSectionSummary>(
  sections.map((s) => [
    s.data.sectionCode,
    {
      sectionCode: s.data.sectionCode,
      sectionCodeDisplay: s.data.sectionCodeDisplay,
      title: s.data.title,
      partNumber: s.data.partNumber,
      divisionId: s.data.divisionId,
    },
  ])
);

// Build sectionCodes per article from the per-section mapping files
const articleSectionCodes = new Map<string, Set<string>>();
for (const mapping of wikiMappings) {
  for (const m of mapping.data.mappings) {
    if (!articleSectionCodes.has(m.articleTitle)) articleSectionCodes.set(m.articleTitle, new Set());
    articleSectionCodes.get(m.articleTitle)!.add(mapping.data.sectionCode);
  }
}

// Build article list from catalog with section codes attached
const articles = (wikiCatalog as any).articles.map((a: any) => ({
  ...a,
  sectionCodes: [...(articleSectionCodes.get(a.title) || [])],
}));

const entries = buildWikipediaAggregateEntries(articles, sectionLookup);
---

<BaseLayout
  title="Wikipedia Vital Articles — Propaedia"
  description="Browse Wikipedia's most important articles mapped to the Propaedia outline, with three knowledge zoom levels."
>
  <main id="main-content" class="mx-auto w-full max-w-screen-2xl px-4 py-8 sm:px-6 lg:px-8">
    <header class="max-w-4xl">
      <p class="text-sm font-medium uppercase tracking-[0.2em] text-gray-500">Reading Lists</p>
      <h1 class="mt-3 font-serif text-4xl text-gray-900 sm:text-5xl">Wikipedia Vital Articles</h1>
      <p class="mt-4 max-w-3xl text-base leading-relaxed text-gray-600 sm:text-lg">
        Wikipedia's curated list of the most important articles, mapped to Propaedia sections.
        Use the knowledge zoom to switch between a focused overview or a broader survey. Check
        off articles as you read them and track your coverage of the outline.
      </p>
    </header>

    <section class="mt-10">
      <WikipediaLibrary client:load entries={entries} baseUrl={base} />
    </section>
  </main>
</BaseLayout>
