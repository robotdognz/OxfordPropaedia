---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import WikipediaLibrary from '../../components/content/WikipediaLibrary';
import { buildWikipediaAggregateEntries, type ReadingSectionSummary } from '../../utils/readingData';
import { analyzeSubsectionCoverage, buildOutlineItemCoverage, buildSectionOutlinePathIndex } from '../../utils/outlineCoverage';
import wikiCatalog from '../../data/wikipedia-catalog.json';
import { getCollection } from 'astro:content';
import { loadOutlineGraph } from '../../utils/outlineGraph';

const base = import.meta.env.BASE_URL;
const sections = await getCollection('sections');
const wikiMappings = await getCollection('wiki-mappings');
const outline = await loadOutlineGraph();

const sectionLookup = new Map<string, ReadingSectionSummary>(
  sections.map((s) => [
    s.data.sectionCode,
    {
      sectionCode: s.data.sectionCode,
      sectionCodeDisplay: s.data.sectionCodeDisplay,
      title: s.data.title,
      partNumber: s.data.partNumber,
      partTitle: outline.sectionMeta[s.data.sectionCode]?.partTitle,
      divisionId: s.data.divisionId,
      divisionTitle: outline.sectionMeta[s.data.sectionCode]?.divisionTitle,
    },
  ])
);

// Build sectionCodes per article from the per-section mapping files
const sectionOutlinePathIndex = buildSectionOutlinePathIndex(sections.map((entry) => entry.data));
const articleCoverage = new Map<string, {
  sectionCodes: Set<string>;
  subsectionKeys: Set<string>;
  mappedPathCount: number;
  mappedPathSections: Set<string>;
  fallbackSections: Set<string>;
}>();
for (const mapping of wikiMappings) {
  for (const m of mapping.data.mappings) {
    if (!articleCoverage.has(m.articleTitle)) {
      articleCoverage.set(m.articleTitle, {
        sectionCodes: new Set(),
        subsectionKeys: new Set(),
        mappedPathCount: 0,
        mappedPathSections: new Set(),
        fallbackSections: new Set(),
      });
    }

    const coverage = articleCoverage.get(m.articleTitle)!;
    coverage.sectionCodes.add(mapping.data.sectionCode);
    const subsectionCoverage = analyzeSubsectionCoverage(
      mapping.data.sectionCode,
      m.relevantPathsAI,
      sectionOutlinePathIndex
    );

    subsectionCoverage.coverageKeys.forEach((key) => coverage.subsectionKeys.add(key));
    coverage.mappedPathCount += subsectionCoverage.matchedPathKeys.length;
    if (subsectionCoverage.matchedPathKeys.length > 0) {
      coverage.mappedPathSections.add(mapping.data.sectionCode);
    }
    if (subsectionCoverage.usedFallback) {
      coverage.fallbackSections.add(mapping.data.sectionCode);
    }
  }
}

// Build article list from catalog with section codes attached
const articles = (wikiCatalog as any).articles.map((a: any) => ({
  ...a,
  sectionCodes: [...(articleCoverage.get(a.title)?.sectionCodes || [])],
  subsectionKeys: [...(articleCoverage.get(a.title)?.subsectionKeys || [])],
  mappedPathCount: articleCoverage.get(a.title)?.mappedPathCount || 0,
  mappedPathSectionCount: articleCoverage.get(a.title)?.mappedPathSections.size || 0,
  fallbackSectionCount: articleCoverage.get(a.title)?.fallbackSections.size || 0,
}));

const entries = buildWikipediaAggregateEntries(articles, sectionLookup);
const { outlineItemCounts, totalOutlineItems } = buildOutlineItemCoverage(
  sections.map((entry) => entry.data)
);
---

<BaseLayout
  title="Wikipedia Articles — Propaedia"
  description="Browse Wikipedia's most important articles mapped to the Propaedia outline, with three zoom levels for different reading goals."
>
  <main id="main-content" class="mx-auto w-full max-w-screen-2xl px-4 py-8 sm:px-6 lg:px-8">
    <header class="max-w-4xl">
      <p class="text-sm font-medium uppercase tracking-[0.2em] text-gray-500">Reading Lists</p>
      <h1 class="mt-3 font-serif text-4xl text-gray-900 sm:text-5xl">Wikipedia Articles</h1>
      <p class="mt-4 max-w-3xl text-base leading-relaxed text-gray-600 sm:text-lg">
        Wikipedia's <a href="https://en.wikipedia.org/wiki/Wikipedia:Vital_articles" target="_blank" rel="noopener noreferrer" class="text-indigo-600 hover:text-indigo-800 underline">Vital Articles</a> are
        a community-curated list of the most important articles on Wikipedia, organised into three tiers.
        Use the zoom level to match how much reading you want to do: Level 1 gives you a broad sweep of
        all human knowledge in just 10 articles, Level 2 expands to 100 for more depth, and Level 3
        opens up roughly 1,000 articles for comprehensive coverage. Start wide to frontload a diverse
        foundation, then zoom in to go deeper where it matters to you. Each article is mapped to Propaedia
        Sections — check them off as you read and track your progress across the outline.
      </p>
    </header>

    <section class="mt-10">
      <WikipediaLibrary
        client:load
        entries={entries}
        baseUrl={base}
        outlineItemCounts={outlineItemCounts}
        totalOutlineItems={totalOutlineItems}
      />
    </section>
  </main>
</BaseLayout>
