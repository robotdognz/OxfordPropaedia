---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import CoverageRings from '../../components/ui/CoverageRings';
import ReadingCheckbox from '../../components/content/ReadingCheckbox';
import { sectionUrl, slugify } from '../../utils/helpers';
import { wikipediaChecklistKey } from '../../utils/readingChecklist';
import wikiCatalog from '../../data/wikipedia-catalog.json';
import { getCollection } from 'astro:content';
import { loadOutlineGraph } from '../../utils/outlineGraph';

export async function getStaticPaths() {
  const outline = await loadOutlineGraph();
  const totals = {
    parts: outline.totals.parts,
    divisions: outline.totals.divisions,
    sections: outline.totals.sections,
  };

  // Build section codes per article from per-section mapping files
  const wikiMappings = await getCollection('wiki-mappings');
  const articleSectionCodes = new Map<string, Array<{ sectionCode: string; relevantPathsAI: string[] }>>();
  for (const mapping of wikiMappings) {
    for (const m of mapping.data.mappings) {
      if (!articleSectionCodes.has(m.articleTitle)) articleSectionCodes.set(m.articleTitle, []);
      articleSectionCodes.get(m.articleTitle)!.push({
        sectionCode: mapping.data.sectionCode,
        relevantPathsAI: m.relevantPathsAI ?? [],
      });
    }
  }

  return (wikiCatalog as any).articles.map((article: any) => {
    const codes = articleSectionCodes.get(article.title) || [];
    const sections = codes.map((entry) => ({
      sectionCode: entry.sectionCode,
      relevantPathsAI: entry.relevantPathsAI,
      meta: outline.sectionMeta[entry.sectionCode],
    })).filter((s: any) => s.meta);

    const coveredParts = new Set(sections.map((s: any) => s.meta.partNumber));
    const coveredDivisions = new Set(sections.map((s: any) => s.meta.divisionId));
    const coverage = { parts: coveredParts.size, divisions: coveredDivisions.size, sections: sections.length };

    return {
      params: { slug: slugify(article.title) },
      props: { article, sections, coverage, totals },
    };
  });
}

const base = import.meta.env.BASE_URL;
const { article, sections, coverage, totals } = Astro.props;

const byPart = new Map<number, typeof sections>();
for (const s of sections) {
  const arr = byPart.get(s.meta.partNumber) || [];
  arr.push(s);
  byPart.set(s.meta.partNumber, arr);
}
const sortedParts = [...byPart.entries()].sort((a, b) => a[0] - b[0]);

const rings = [
  { label: 'Parts', count: coverage.parts, total: totals.parts, color: '#6366f1' },
  { label: 'Divisions', count: coverage.divisions, total: totals.divisions, color: '#8b5cf6' },
  { label: 'Sections', count: coverage.sections, total: totals.sections, color: '#a78bfa' },
];

const levelLabels: Record<number, string> = { 1: 'Level 1 (Top 10)', 2: 'Level 2 (Top 100)', 3: 'Level 3 (~1,000)' };
const levelLabel = levelLabels[article.lowestLevel] || 'Level 3';
---

<BaseLayout title={`${article.displayTitle || article.title} — Wikipedia`} description={`Wikipedia vital article: ${article.title}`}>
  <main id="main-content" class="mx-auto w-full max-w-4xl px-4 py-8 sm:px-6 lg:px-8">
    <nav class="mb-6 text-sm text-gray-500 font-sans">
      <a href={`${base}/`} class="hover:text-indigo-700">Home</a>
      <span class="mx-1">/</span>
      <a href={`${base}/wikipedia`} class="hover:text-indigo-700">Wikipedia</a>
      <span class="mx-1">/</span>
      <span class="text-gray-900">{article.displayTitle || article.title}</span>
    </nav>

    <header>
      <p class="text-sm font-sans font-semibold uppercase tracking-[0.2em] text-gray-500">Wikipedia Vital Article</p>
      <h1 class="mt-2 text-3xl font-serif font-bold text-gray-900 sm:text-4xl" data-pagefind-meta={`title:${article.displayTitle || article.title}`}>{article.displayTitle || article.title}</h1>
      <span data-pagefind-meta="page_type:Wikipedia" class="hidden"></span>
      <div class="mt-2 flex flex-wrap gap-2">
        {article.category && (
          <span class="inline-block rounded-full bg-gray-100 px-2.5 py-0.5 text-xs text-gray-600">{article.category}</span>
        )}
        <span class="inline-block rounded-full bg-indigo-50 px-2.5 py-0.5 text-xs text-indigo-700">{levelLabel}</span>
      </div>
      <div class="mt-3 flex flex-wrap items-center gap-4">
        <ReadingCheckbox client:idle checklistKey={wikipediaChecklistKey(article.title)} />
        <a
          href={article.url}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1 text-sm text-indigo-600 hover:text-indigo-800"
        >
          Read on Wikipedia ↗
        </a>
      </div>
    </header>

    <div class="mt-8 flex items-start gap-4 rounded-xl border border-slate-200 bg-slate-50 px-5 py-4">
      <div class="flex-1 min-w-0">
        <h2 class="text-sm font-sans font-semibold uppercase tracking-[0.18em] text-gray-500">
          {sections.length > 0
            ? `Mapped to ${sections.length} ${sections.length === 1 ? 'Section' : 'Sections'}`
            : 'No matching sections'}
        </h2>
        <p class="mt-1 text-xs text-slate-400">Coverage across the Outline of Knowledge</p>
      </div>
      <div class="shrink-0">
        <CoverageRings client:load rings={rings} size={100} ringWidth={8} />
      </div>
    </div>

    {sections.length > 0 ? (
      <section class="mt-6">
        {sortedParts.map(([partNumber, partSections]) => (
          <div class="mt-4">
            <h3 class="text-xs font-sans font-semibold uppercase tracking-[0.15em] text-gray-400">
              Part {partNumber}: {partSections[0].meta.partTitle}
            </h3>
            <ul class="mt-2 space-y-2">
              {partSections.map((s) => (
                <li class="rounded-lg border border-gray-200 bg-white px-4 py-3">
                  <div class="flex flex-wrap items-start justify-between gap-3">
                    <div class="min-w-0">
                      <a
                        href={sectionUrl(s.sectionCode, base)}
                        class="text-sm font-semibold text-gray-900 hover:text-indigo-700"
                      >
                        Section {s.sectionCode}: {s.meta.sectionTitle}
                      </a>
                      <p class="mt-0.5 text-xs text-gray-400">{s.meta.divisionTitle}</p>
                    </div>
                    <span class={`inline-flex items-center rounded-full border px-2.5 py-1 text-[11px] font-semibold ${s.relevantPathsAI?.length ? 'border-indigo-200 bg-indigo-50 text-indigo-700' : 'border-slate-200 bg-slate-100 text-slate-700'}`}>
                      {s.relevantPathsAI?.length
                        ? `${s.relevantPathsAI.length} mapped ${s.relevantPathsAI.length === 1 ? 'path' : 'paths'}`
                        : 'Broader Section coverage'}
                    </span>
                  </div>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </section>
    ) : (
      <section class="mt-8">
        <p class="text-sm text-gray-400 italic">This article does not match any sections in the Outline of Knowledge.</p>
      </section>
    )}
  </main>
</BaseLayout>
