---
import BaseLayout from '../components/layout/BaseLayout.astro';
import CacheDebugPanel from '../components/content/CacheDebugPanel';
import OfflineSiteCachePanel from '../components/content/OfflineSiteCachePanel';

const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="Offline Use - Propaedia"
  description="Download the full Propaedia site into browser storage for offline use."
>
  <main id="main-content" class="mx-auto w-full max-w-4xl px-4 py-8 sm:px-8">
    <div class="mb-6 max-w-2xl space-y-3">
      <p class="text-sm font-sans font-semibold uppercase tracking-[0.2em] text-slate-500">
        Offline Use
      </p>
      <h1 class="font-serif text-4xl text-slate-900">Store the site for offline reading</h1>
      <p class="text-base leading-7 text-slate-600">
        Core outline pages are already available offline once the site is installed. Use this page if you want to save
        the full site on this device as well.
      </p>
    </div>

    <div class="space-y-4">
      <OfflineSiteCachePanel client:only="preact" baseUrl={base} />
      <CacheDebugPanel client:only="preact" />
    </div>
  </main>
</BaseLayout>
