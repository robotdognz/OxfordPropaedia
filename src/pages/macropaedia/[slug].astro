---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import CoverageRings from '../../components/ui/CoverageRings';
import { getCollection } from 'astro:content';
import { sectionUrl, slugify } from '../../utils/helpers';
import { loadOutlineGraph } from '../../utils/outlineGraph';

export async function getStaticPaths() {
  const outline = await loadOutlineGraph();
  const totals = {
    parts: outline.totals.parts,
    divisions: outline.totals.divisions,
    sections: outline.totals.sections,
  };

  const sections = await getCollection('sections');
  const articleMap = new Map<string, { title: string; sections: { sectionCode: string; meta: (typeof outline.sectionMeta)[string] }[] }>();

  for (const section of sections) {
    for (const ref of section.data.macropaediaReferences ?? []) {
      const title = ref.replace(/\s+/g, ' ').trim();
      const articleSlug = slugify(title);
      const meta = outline.sectionMeta[section.data.sectionCode];
      if (!meta) continue;

      const existing = articleMap.get(articleSlug);
      if (existing) {
        if (!existing.sections.some(s => s.sectionCode === section.data.sectionCode)) {
          existing.sections.push({ sectionCode: section.data.sectionCode, meta });
        }
      } else {
        articleMap.set(articleSlug, { title, sections: [{ sectionCode: section.data.sectionCode, meta }] });
      }
    }
  }

  return [...articleMap.entries()].map(([slug, article]) => {
    const coveredParts = new Set(article.sections.map(s => s.meta.partNumber));
    const coveredDivisions = new Set(article.sections.map(s => s.meta.divisionId));
    const coverage = {
      parts: coveredParts.size,
      divisions: coveredDivisions.size,
      sections: article.sections.length,
    };
    return { params: { slug }, props: { article, coverage, totals } };
  });
}

const base = import.meta.env.BASE_URL;
const { article, coverage, totals } = Astro.props;

// Group by part
const byPart = new Map<number, typeof article.sections>();
for (const s of article.sections) {
  const arr = byPart.get(s.meta.partNumber) || [];
  arr.push(s);
  byPart.set(s.meta.partNumber, arr);
}
const sortedParts = [...byPart.entries()].sort((a, b) => a[0] - b[0]);

// Ring chart
const rings = [
  { label: 'Parts', count: coverage.parts, total: totals.parts, color: '#6366f1' },
  { label: 'Divisions', count: coverage.divisions, total: totals.divisions, color: '#8b5cf6' },
  { label: 'Sections', count: coverage.sections, total: totals.sections, color: '#a78bfa' },
];

---

<BaseLayout title={`${article.title} — Macropaedia`} description={`Macropaedia article: ${article.title}`}>
  <main id="main-content" class="mx-auto w-full max-w-4xl px-4 py-8 sm:px-6 lg:px-8">
    <nav class="mb-6 text-sm text-gray-500 font-sans">
      <a href={`${base}/`} class="hover:text-indigo-700">Home</a>
      <span class="mx-1">/</span>
      <a href={`${base}/macropaedia`} class="hover:text-indigo-700">Macropaedia</a>
      <span class="mx-1">/</span>
      <span class="text-gray-900">{article.title}</span>
    </nav>

    <header>
      <p class="text-sm font-sans font-semibold uppercase tracking-[0.2em] text-gray-500">Macropaedia Article</p>
      <h1 class="mt-2 text-3xl font-serif font-bold text-gray-900 sm:text-4xl" data-pagefind-meta={`title:${article.title}`}>{article.title}</h1>
      <span data-pagefind-meta="page_type:Macropaedia" class="hidden"></span>
    </header>

    <div class="mt-8 flex items-start gap-4 rounded-xl border border-slate-200 bg-slate-50 px-5 py-4">
      <div class="flex-1 min-w-0">
        <h2 class="text-sm font-sans font-semibold uppercase tracking-[0.18em] text-gray-500">
          Referenced in {article.sections.length} {article.sections.length === 1 ? 'Section' : 'Sections'}
        </h2>
        <p class="mt-1 text-xs text-slate-400">Coverage across the Outline of Knowledge</p>
      </div>
      <div class="shrink-0">
        <CoverageRings client:load rings={rings} size={100} ringWidth={8} />
      </div>
    </div>

    <section class="mt-6">
      {sortedParts.map(([partNumber, sections]) => (
        <div class="mt-4">
          <h3 class="text-xs font-sans font-semibold uppercase tracking-[0.15em] text-gray-400">
            Part {partNumber}: {sections[0].meta.partTitle}
          </h3>
          <ul class="mt-2 space-y-2">
            {sections.map((s) => (
              <li class="rounded-lg border border-gray-200 bg-white px-4 py-3">
                <a
                  href={sectionUrl(s.sectionCode, base)}
                  class="text-sm font-semibold text-gray-900 hover:text-indigo-700"
                >
                  Section {s.sectionCode}: {s.meta.sectionTitle}
                </a>
                <p class="mt-0.5 text-xs text-gray-400">{s.meta.divisionTitle}</p>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </section>
  </main>
</BaseLayout>
