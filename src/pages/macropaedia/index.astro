---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import MacropaediaLibrary from '../../components/content/MacropaediaLibrary';
import { getCollection } from 'astro:content';
import { buildMacropaediaAggregateEntries } from '../../utils/readingData';
import { loadOutlineGraph } from '../../utils/outlineGraph';

const base = import.meta.env.BASE_URL;
const sections = await getCollection('sections');
const outline = await loadOutlineGraph();

const sectionsWithMeta = sections.map((entry) => {
  const meta = outline.sectionMeta[entry.data.sectionCode];
  return {
    ...entry.data,
    partTitle: meta?.partTitle,
    divisionTitle: meta?.divisionTitle,
  };
});

const entries = buildMacropaediaAggregateEntries(sectionsWithMeta);
---

<BaseLayout
  title="Britannica Articles — Propaedia"
  description="Browse the Macropaedia articles referenced in the Propaedia outline — long-form Britannica articles providing in-depth treatment of major subjects."
>
  <main id="main-content" class="mx-auto w-full max-w-screen-2xl px-4 py-8 sm:px-6 lg:px-8">
    <header class="max-w-4xl">
      <p class="text-sm font-medium uppercase tracking-[0.2em] text-gray-500">Reading Type</p>
      <h1 class="mt-3 font-serif text-4xl text-gray-900 sm:text-5xl">Britannica Articles</h1>
      <p class="mt-4 max-w-3xl text-base leading-relaxed text-gray-600 sm:text-lg">
        The Macropaedia was the long-form heart of the <a href="https://www.britannica.com/" target="_blank" rel="noopener noreferrer" class="text-indigo-600 hover:text-indigo-800 underline">Encyclopaedia Britannica</a> —
        in-depth articles of 10 to 300+ pages written by leading scholars on major subjects.
        The Propaedia outline references these articles as the primary reading for each Section.
        Browse the full list below, see which articles span the most Sections, and track your progress
        alongside the VSI and Wikipedia reading types.
      </p>
    </header>

    <section class="mt-8">
      <MacropaediaLibrary
        client:load
        entries={entries}
        baseUrl={base}
      />
    </section>
  </main>
</BaseLayout>
