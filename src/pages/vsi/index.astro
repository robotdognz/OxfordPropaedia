---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import VsiLibrary from '../../components/content/VsiLibrary';
import { getCollection } from 'astro:content';
import { buildVsiAggregateEntries } from '../../utils/readingData';
import { buildOutlineItemCoverage } from '../../utils/outlineCoverage';
import { loadOutlineGraph } from '../../utils/outlineGraph';

const base = import.meta.env.BASE_URL;
const sections = await getCollection('sections');
const mappings = await getCollection('vsi-mappings');
const catalogCollections = await getCollection('vsi');
const outline = await loadOutlineGraph();

const sectionsWithMeta = sections.map((entry) => {
  const meta = outline.sectionMeta[entry.data.sectionCode];
  return {
    ...entry.data,
    partTitle: meta?.partTitle,
    divisionTitle: meta?.divisionTitle,
  };
});

const entries = buildVsiAggregateEntries(
  sectionsWithMeta,
  mappings.map((entry) => entry.data),
  catalogCollections.flatMap((entry) => entry.data.titles)
);

const { outlineItemCounts, totalOutlineItems } = buildOutlineItemCoverage(
  sections.map((entry) => entry.data)
);
---

<BaseLayout
  title="Oxford VSI Library — Propaedia"
  description="Browse every Oxford Very Short Introduction mapped into the Propaedia, ranked by how widely each title appears across Sections."
>
  <main id="main-content" class="mx-auto w-full max-w-screen-2xl px-4 py-8 sm:px-6 lg:px-8">
    <header class="max-w-4xl">
      <p class="text-sm font-medium uppercase tracking-[0.2em] text-gray-500">Reading Type</p>
      <h1 class="mt-3 font-serif text-4xl text-gray-900 sm:text-5xl">Oxford Very Short Introductions</h1>
      <p class="mt-4 max-w-3xl text-base leading-relaxed text-gray-600 sm:text-lg">
        Oxford's <a href="https://global.oup.com/academic/content/series/v/very-short-introductions-vsi" target="_blank" rel="noopener noreferrer" class="text-indigo-600 hover:text-indigo-800 underline">Very Short Introductions</a> are
        concise, expert-written books that cover a subject in roughly 150 pages. Each title below has been mapped to the
        Propaedia Sections it relates to, so you can see which books give the widest spread across the outline of knowledge.
        Check off titles as you read them and follow a reading path that adapts to what you've already covered.
      </p>
    </header>

    <section class="mt-8">
      <VsiLibrary client:load entries={entries} baseUrl={base} outlineItemCounts={outlineItemCounts} totalOutlineItems={totalOutlineItems} />
    </section>
  </main>
</BaseLayout>
