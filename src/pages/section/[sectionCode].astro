---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import Breadcrumbs from '../../components/layout/Breadcrumbs.astro';
import Sidebar from '../../components/layout/Sidebar.astro';
import OutlineTree from '../../components/content/OutlineTree';
import MacropaediaRefs from '../../components/content/MacropaediaRefs';
import WikipediaRefs from '../../components/content/WikipediaRefs';
import VsiRecommendations from '../../components/content/VsiRecommendations';
import CrossRefLink from '../../components/content/CrossRefLink';
import navigation from '../../data/navigation.json';
import crossReferences from '../../data/cross-references.json';
import wikiCatalog from '../../data/wikipedia-catalog.json';
import { getCollection } from 'astro:content';
import { computeWikiRelevanceScore, tokenize } from '../../utils/wikipediaOutlineFilter';

export async function getStaticPaths() {
  const sections = await getCollection('sections');
  return sections.map((section) => ({
    // Normalize slashes to hyphens for URL-safe paths (e.g., "10/12" → "10-12")
    params: { sectionCode: section.data.sectionCode.replace(/\//g, '-') },
    props: { section: section.data },
  }));
}

const { section } = Astro.props;
const base = import.meta.env.BASE_URL;

const PART_NAMES: Record<number, string> = {
  1: 'One', 2: 'Two', 3: 'Three', 4: 'Four', 5: 'Five',
  6: 'Six', 7: 'Seven', 8: 'Eight', 9: 'Nine', 10: 'Ten',
};

// Find parent part and division
const parentPart = navigation.parts.find((p) => p.partNumber === section.partNumber);
const parentDiv = parentPart?.divisions.find((d) => d.divisionId === section.divisionId);

const partTextColors: Record<number, string> = {
  1: 'text-blue-800',
  2: 'text-emerald-800',
  3: 'text-green-700',
  4: 'text-red-700',
  5: 'text-violet-700',
  6: 'text-orange-700',
  7: 'text-cyan-700',
  8: 'text-indigo-700',
  9: 'text-pink-700',
  10: 'text-amber-700',
};

// Get reverse cross-references ("Referenced by")
const reverseRefs = (crossReferences.reverseIndex as Record<string, any[]>)[section.sectionCode] ?? [];

// Try to load VSI mappings for this section
let vsiMappings: any[] = [];
const normalizeVsiText = (text: string) => text.replace(/\s+/g, ' ').trim().toLowerCase();

try {
  const allVsiMappings = await getCollection('vsi-mappings');
  const vsiCatalogCollections = await getCollection('vsi');
  const vsiCatalog = vsiCatalogCollections.flatMap((entry) => entry.data.titles);
  const vsiCatalogLookup = new Map(
    vsiCatalog.map((entry) => [
      `${normalizeVsiText(entry.title)}::${normalizeVsiText(entry.author)}`,
      entry,
    ])
  );
  const mapping = allVsiMappings.find((m) => m.data.sectionCode === section.sectionCode);
  if (mapping) {
    vsiMappings = mapping.data.mappings.map((entry) => {
      const catalogEntry = vsiCatalogLookup.get(
        `${normalizeVsiText(entry.vsiTitle)}::${normalizeVsiText(entry.vsiAuthor)}`
      );

      return {
        ...entry,
        publicationYear: catalogEntry?.publicationYear,
        edition: catalogEntry?.edition,
        subject: catalogEntry?.subject,
        keywords: catalogEntry?.keywords,
        abstract: catalogEntry?.abstract,
      };
    });
  }
} catch {
  // No VSI mappings yet
}

// Pre-compute Wikipedia article scores for this section
function collectOutlineText(nodes: any[]): string {
  let t = '';
  for (const nd of nodes || []) { t += ' ' + (nd.text || ''); t += collectOutlineText(nd.children); }
  return t;
}
const sectionTokens = tokenize(section.title + ' ' + collectOutlineText(section.outline));

// Load Wikipedia mappings for this section from the per-section file
const wikiCatalogLookup = new Map((wikiCatalog as any).articles.map((a: any) => [a.title, a]));
let wikiArticlesForSection: any[] = [];
try {
  const allWikiMappings = await getCollection('wiki-mappings');
  const wikiMapping = allWikiMappings.find((m) => m.data.sectionCode === section.sectionCode);
  if (wikiMapping) {
    wikiArticlesForSection = wikiMapping.data.mappings.map((entry) => {
      const catalogEntry = wikiCatalogLookup.get(entry.articleTitle);
      return {
        title: entry.articleTitle,
        displayTitle: catalogEntry?.displayTitle,
        url: catalogEntry?.url || `https://en.wikipedia.org/wiki/${entry.articleTitle.replace(/ /g, '_')}`,
        category: catalogEntry?.category,
        lowestLevel: catalogEntry?.lowestLevel || 3,
        extract: catalogEntry?.extract,
        toc: catalogEntry?.toc,
        wikiCategories: catalogEntry?.wikiCategories,
        rationale: entry.rationaleAI || '',
        relevantPathsAI: entry.relevantPathsAI || [],
        _score: computeWikiRelevanceScore(
          { title: entry.articleTitle, category: catalogEntry?.category, toc: catalogEntry?.toc, wikiCategories: catalogEntry?.wikiCategories },
          sectionTokens,
        ),
      };
    });
    const maxWikiScore = Math.max(...wikiArticlesForSection.map((a: any) => a._score), 1);
    wikiArticlesForSection = wikiArticlesForSection
      .map((a: any) => ({ ...a, matchPercent: Math.round(Math.min(a._score / maxWikiScore, 1) * 100) }))
      .sort((a: any, b: any) => b._score - a._score);
  }
} catch {
  // No wiki mappings yet
}

const breadcrumbItems = [
  { label: 'Home', href: `${base}/` },
  { label: `Part ${PART_NAMES[section.partNumber]}: ${parentPart?.title ?? ''}`, href: `${base}/part/${section.partNumber}` },
  { label: `Division ${parentDiv?.romanNumeral ?? ''}: ${parentDiv?.title ?? ''}`, href: `${base}/division/${section.divisionId}` },
  { label: `Section ${section.sectionCodeDisplay}: ${section.title}` },
];
---

<BaseLayout title={`Section ${section.sectionCodeDisplay}: ${section.title} — Propaedia`}>
  <div class="flex min-h-screen">
    <Sidebar
      navigation={navigation.parts}
      currentPartNumber={section.partNumber}
      currentDivisionId={section.divisionId}
      currentSectionCode={section.sectionCode}
    />

    <main id="main-content" class="flex-1 min-w-0 px-4 sm:px-8 py-6">
      <Breadcrumbs items={breadcrumbItems} />

      <header class="mb-8">
        <p class={`text-sm font-sans font-medium uppercase tracking-wide mb-1 ${partTextColors[section.partNumber]}`}>
          Part {PART_NAMES[section.partNumber]} &middot; Division {parentDiv?.romanNumeral ?? ''} &middot; Section {section.sectionCodeDisplay}
        </p>
        <h1 class="text-3xl sm:text-4xl font-serif font-bold text-gray-900">
          {section.title}
        </h1>
      </header>

      <!-- Subject Outline -->
      <section class="mb-8">
        <details class="group" open>
          <summary class="cursor-pointer text-xl font-sans font-semibold text-gray-800 flex items-center gap-2 mb-4">
            <svg class="w-5 h-5 transition-transform group-open:rotate-90" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
            Subject Outline
          </summary>
          <div class="pl-2">
            <OutlineTree
              client:load
              items={section.outline}
              sectionCode={section.sectionCode}
              baseUrl={base}
              currentHref={`${base}/section/${section.sectionCode.replace(/\//g, '-')}`}
            />
          </div>
        </details>
      </section>

      {reverseRefs.length > 0 && (
        <section class="mb-8">
          <details class="group rounded-lg border border-gray-200">
            <summary class="cursor-pointer list-none bg-gray-50 px-4 py-3 font-serif text-sm font-semibold text-gray-800 [&::-webkit-details-marker]:hidden">
              <div class="flex items-center justify-between gap-3">
                <span>Referenced by other sections</span>
                <svg
                  class="h-4 w-4 text-gray-500 transition-transform group-open:rotate-180"
                  xmlns="http://www.w3.org/2000/svg"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                  aria-hidden="true"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </div>
            </summary>
            <div class="px-4 py-3">
              <div class="flex flex-wrap gap-2">
                {reverseRefs.map((ref: any) => (
                  <CrossRefLink
                    client:visible
                    targetSection={ref.sourceSection}
                    targetPath={ref.sourcePath}
                    baseUrl={base}
                  />
                ))}
              </div>
            </div>
          </details>
        </section>
      )}

      <!-- VSI Recommendations -->
      {vsiMappings.length > 0 && (() => {
        function collectOutlineText(nodes: any[]): string {
          let text = '';
          (nodes || []).forEach((n: any) => { text += ' ' + (n.text || ''); text += collectOutlineText(n.children); });
          return text;
        }
        const outlineText = collectOutlineText(section.outline).trim();
        return (
        <section class="mb-8">
          <VsiRecommendations
            client:load
            mappings={vsiMappings}
            sectionCode={section.sectionCode}
            sectionTitle={section.title}
            sectionOutlineText={outlineText}
            baseUrl={base}
          />
        </section>
        );
      })()}

      <!-- Wikipedia Article Recommendations -->
      {wikiArticlesForSection.length > 0 && (
        <section class="mb-8">
          <WikipediaRefs
            client:load
            articles={wikiArticlesForSection}
            sectionCode={section.sectionCode}
            baseUrl={base}
          />
        </section>
      )}

      <!-- Macropaedia References -->
      {section.macropaediaReferences.length > 0 && (
        <section class="mb-8">
          <MacropaediaRefs
            client:load
            references={section.macropaediaReferences}
            baseUrl={base}
          />
        </section>
      )}
    </main>
  </div>
</BaseLayout>
