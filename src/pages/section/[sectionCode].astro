---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import StickySubheading from '../../components/layout/StickySubheading.astro';
import OutlineTree from '../../components/content/OutlineTree';
import MacropaediaRefs from '../../components/content/MacropaediaRefs';
import WikipediaRefs from '../../components/content/WikipediaRefs';
import VsiRecommendations from '../../components/content/VsiRecommendations';
import { getCollection } from 'astro:content';
import { sectionReferenceUrl } from '../../utils/helpers';
import { loadOutlineGraph } from '../../utils/outlineGraph';
import { loadSectionReadingContext } from '../../utils/sectionReadingContext';

export async function getStaticPaths() {
  const sections = await getCollection('sections');
  return sections.map((section) => ({
    // Normalize slashes to hyphens for URL-safe paths (e.g., "10/12" → "10-12")
    params: { sectionCode: section.data.sectionCode.replace(/\//g, '-') },
    props: { section: section.data },
  }));
}

const { section } = Astro.props;
const base = import.meta.env.BASE_URL;
const outline = await loadOutlineGraph();

const PART_NAMES: Record<number, string> = {
  1: 'One', 2: 'Two', 3: 'Three', 4: 'Four', 5: 'Five',
  6: 'Six', 7: 'Seven', 8: 'Eight', 9: 'Nine', 10: 'Ten',
};

// Find parent part and division
const parentPart = outline.partByNumber.get(section.partNumber);
const parentDiv = outline.divisionById.get(section.divisionId);

const partTextColors: Record<number, string> = {
  1: 'text-blue-800',
  2: 'text-emerald-800',
  3: 'text-green-700',
  4: 'text-red-700',
  5: 'text-violet-700',
  6: 'text-orange-700',
  7: 'text-cyan-700',
  8: 'text-indigo-700',
  9: 'text-pink-700',
  10: 'text-amber-700',
};

const currentIndex = outline.sectionIndexByCode.get(section.sectionCode) ?? -1;
const prevSection = currentIndex > 0 ? outline.flatSections[currentIndex - 1] : null;
const nextSection = currentIndex >= 0 && currentIndex < outline.flatSections.length - 1
  ? outline.flatSections[currentIndex + 1]
  : null;

const {
  reverseRefs,
  groupedReverseRefs,
  vsiMappings,
  wikiArticlesForSection,
} = await loadSectionReadingContext(section);

---

<BaseLayout title={`Section ${section.sectionCodeDisplay}: ${section.title} — Propaedia`} currentPartNumber={section.partNumber} currentDivisionId={section.divisionId} currentSectionCode={section.sectionCode}>
    <main id="main-content" class="flex-1 min-w-0">
      <StickySubheading
        breadcrumbs={[
          { label: `Part ${PART_NAMES[section.partNumber]}`, href: `${base}/part/${section.partNumber}` },
          { label: `Division ${parentDiv?.romanNumeral ?? ''}`, href: `${base}/division/${section.divisionId}` },
          { label: `Section ${section.sectionCodeDisplay}`, mobileLabel: section.sectionCodeDisplay },
        ]}
        scrollTargets={[
          { id: 'subject-outline', label: 'Outline' },
          { id: 'readings', label: 'Readings' },
        ]}
        colorClass={partTextColors[section.partNumber]}
      />

      <div class="px-4 sm:px-8 py-6">
      <header class="mb-8">
        <h1 class="text-3xl sm:text-4xl font-serif font-bold text-gray-900" data-pagefind-meta={`title:${section.sectionCodeDisplay}: ${section.title}`}>
          {section.title}
        </h1>
        <span data-pagefind-meta="page_type:Section" class="hidden"></span>
      </header>

      <!-- Subject Outline -->
      <section id="subject-outline" class="mb-8 scroll-mt-24">
        <details class="group" open>
          <summary class="cursor-pointer text-xl font-sans font-semibold text-gray-800 flex items-center gap-2 mb-4">
            <svg class="w-5 h-5 transition-transform group-open:rotate-90" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
            Subject Outline
          </summary>
          <div class="pl-2">
            <OutlineTree
              client:load
              items={section.outline}
              sectionCode={section.sectionCode}
              baseUrl={base}
              currentHref={`${base}/section/${section.sectionCode.replace(/\//g, '-')}`}
            />
          </div>
        </details>
      </section>

      <!-- Reading Recommendations -->
      <div id="readings" class="scroll-mt-24 flex flex-col gap-4 mb-8">
        <div style="order:-2">
          <p class="text-[0.68rem] font-sans font-semibold uppercase tracking-[0.2em] text-slate-500 sm:text-xs">
            Reading Recommendations
          </p>
          <p class="mt-1 text-xs leading-5 text-slate-400 sm:text-sm">
            Books and articles mapped to this section's outline. Click any outline item above to filter recommendations by topic.
          </p>
        </div>
        <!-- VSI Recommendations -->
        {vsiMappings.length > 0 && (() => {
          function collectOutlineText(nodes: any[]): string {
            let text = '';
            (nodes || []).forEach((n: any) => { text += ' ' + (n.text || ''); text += collectOutlineText(n.children); });
            return text;
          }
          const outlineText = collectOutlineText(section.outline).trim();
          return (
          <section data-reading-type="vsi">
            <VsiRecommendations
              client:load
              mappings={vsiMappings}
              sectionCode={section.sectionCode}
              sectionTitle={section.title}
              sectionOutlineText={outlineText}
              baseUrl={base}
            />
          </section>
          );
        })()}

        <!-- Wikipedia Article Recommendations -->
        {wikiArticlesForSection.length > 0 && (
          <section data-reading-type="wikipedia">
            <WikipediaRefs
              client:load
              articles={wikiArticlesForSection}
              sectionCode={section.sectionCode}
              baseUrl={base}
            />
          </section>
        )}

        <!-- Macropaedia References -->
        {section.macropaediaReferences.length > 0 && (
          <section data-reading-type="macropaedia">
            <MacropaediaRefs
              client:load
              references={section.macropaediaReferences}
              sectionCode={section.sectionCode}
              baseUrl={base}
            />
          </section>
        )}
      </div>

      <script is:inline>
        (function() {
          try {
            var pref = localStorage.getItem('propaedia-reading-preference') || 'vsi';
            var container = document.getElementById('readings');
            if (!container) return;
            container.querySelectorAll(':scope > [data-reading-type]').forEach(function(el) {
              el.style.order = el.getAttribute('data-reading-type') === pref ? '-1' : '';
            });
          } catch(e) {}
        })();
      </script>

      <!-- Referenced by other sections -->
      {groupedReverseRefs.length > 0 && (
        <section class="mb-8">
          <details class="group rounded-lg border border-dashed border-slate-300">
            <summary class="cursor-pointer list-none px-4 py-3 font-sans text-xs font-semibold uppercase tracking-wide text-slate-400 [&::-webkit-details-marker]:hidden">
              <div class="flex items-center justify-between gap-3">
                <span>Cross references from other sections ({reverseRefs.length})</span>
                <svg
                  class="h-4 w-4 text-slate-300 transition-transform group-open:rotate-180"
                  xmlns="http://www.w3.org/2000/svg"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                  aria-hidden="true"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </div>
            </summary>
            <div class="px-4 py-4 space-y-4">
              {groupedReverseRefs.map((partGroup) => (
                <div>
                  <p class="text-xs font-sans font-semibold uppercase tracking-wide text-slate-400 mb-2">
                    Part {PART_NAMES[partGroup.partNumber]}: {partGroup.partTitle}
                  </p>
                  {partGroup.divisions.map((divGroup) => (
                    <div class="ml-2 mb-3">
                      <p class="text-xs font-sans font-medium text-slate-500 mb-1">
                        Division {divGroup.romanNumeral}: {divGroup.divisionTitle}
                      </p>
                      <ul class="ml-2 space-y-1">
                        {divGroup.refs.map((ref) => {
                          const displayCode = ref.sourceSection.replace(/-/g, '/');
                          const label = ref.sourcePath ? `${displayCode}.${ref.sourcePath}` : displayCode;
                          const href = sectionReferenceUrl(ref.sourceSection, ref.sourcePath || '', base);
                          return (
                            <li>
                              <a
                                href={href}
                                class="group flex items-start gap-2 rounded px-1 py-0.5 text-sm transition hover:bg-slate-50"
                              >
                                <span class="font-mono text-xs text-slate-400 shrink-0 mt-0.5">{label}</span>
                                <span class="text-slate-700 group-hover:text-indigo-700">{ref.sectionTitle}</span>
                              </a>
                            </li>
                          );
                        })}
                      </ul>
                    </div>
                  ))}
                </div>
              ))}
            </div>
          </details>
        </section>
      )}
      {(prevSection || nextSection) && (
        <nav class="mt-12 flex items-stretch gap-3 border-t border-slate-200 pt-6" aria-label="Section navigation">
          {prevSection ? (
            <a
              href={`${base}/section/${prevSection.sectionCode.replace(/\//g, '-')}`}
              class="group flex min-w-0 flex-1 items-center gap-2 rounded-xl border border-slate-200 px-4 py-3 transition hover:border-slate-300 hover:bg-slate-50"
            >
              <svg class="h-4 w-4 shrink-0 text-slate-400 group-hover:text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
              </svg>
              <div class="min-w-0">
                <p class="text-xs font-sans font-semibold uppercase tracking-wide text-slate-400">Previous</p>
                <p class="truncate text-sm font-serif font-semibold text-slate-700 group-hover:text-slate-900">{prevSection.title}</p>
              </div>
            </a>
          ) : <div class="flex-1" />}
          {nextSection ? (
            <a
              href={`${base}/section/${nextSection.sectionCode.replace(/\//g, '-')}`}
              class="group flex min-w-0 flex-1 items-center justify-end gap-2 rounded-xl border border-slate-200 px-4 py-3 text-right transition hover:border-slate-300 hover:bg-slate-50"
            >
              <div class="min-w-0">
                <p class="text-xs font-sans font-semibold uppercase tracking-wide text-slate-400">Next</p>
                <p class="truncate text-sm font-serif font-semibold text-slate-700 group-hover:text-slate-900">{nextSection.title}</p>
              </div>
              <svg class="h-4 w-4 shrink-0 text-slate-400 group-hover:text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          ) : <div class="flex-1" />}
        </nav>
      )}
      </div>
    </main>
</BaseLayout>
