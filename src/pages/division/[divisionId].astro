---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import StickySubheading from '../../components/layout/StickySubheading.astro';
import NotesDisclosure from '../../components/content/NotesDisclosure.astro';
import TopReadings from '../../components/content/TopReadings';
import ReadingRecommendationsFallback from '../../components/content/ReadingRecommendationsFallback.astro';
import { getCollection } from 'astro:content';
import { loadIotTopReadings } from '../../utils/iotTopReadings';
import { loadOutlineGraph } from '../../utils/outlineGraph';
import { enrichWikipediaReadingItems } from '../../utils/wikipediaCatalog';
import { enrichIotRecommendationItems, enrichVsiRecommendationItems } from '../../utils/recommendationEnrichment';

export async function getStaticPaths() {
  const divisions = await getCollection('divisions');
  return divisions.map((div) => ({
    params: { divisionId: div.data.divisionId },
    props: { division: div.data },
  }));
}

const { division } = Astro.props;
const base = import.meta.env.BASE_URL;
const outline = await loadOutlineGraph();
const sectionEntries = await getCollection('sections');

const PART_NAMES: Record<number, string> = {
  1: 'One', 2: 'Two', 3: 'Three', 4: 'Four', 5: 'Five',
  6: 'Six', 7: 'Seven', 8: 'Eight', 9: 'Nine', 10: 'Ten',
};
const PART_ROMAN: Record<number, string> = {
  1: 'I', 2: 'II', 3: 'III', 4: 'IV', 5: 'V',
  6: 'VI', 7: 'VII', 8: 'VIII', 9: 'IX', 10: 'X',
};

// Find parent part info
const parentPart = outline.partByNumber.get(division.partNumber);
const divNav = parentPart?.divisions.find((d) => d.divisionId === division.divisionId);
const sections = divNav?.sections ?? [];
const topLevelSubsectionCountBySection = new Map(
  sectionEntries.map((entry) => [entry.data.sectionCode, entry.data.outline.length]),
);

// Load reading recommendations for this division
const allDivReadings = await getCollection('division-readings');
const divReadingsEntry = allDivReadings.find((r) => r.data.divisionId === division.divisionId);
const divReadings = divReadingsEntry?.data.readings;
const divisionVsiReadings = enrichVsiRecommendationItems(divReadings?.vsi);
const divisionWikiReadings = enrichWikipediaReadingItems(divReadings?.wiki);
const iotTopReadings = await loadIotTopReadings();
const divisionIotReadings = enrichIotRecommendationItems(iotTopReadings.divisionReadingsByDivision.get(division.divisionId) ?? []);
const divisionCuratedIotReadings = enrichIotRecommendationItems(divReadings?.iot);

// Build flat ordered list of all divisions for prev/next navigation
const allDivisions = outline.flatDivisions.map((entry) => ({
  divisionId: entry.divisionId,
  title: entry.title,
  partNumber: entry.partNumber,
}));
const currentDivIndex = allDivisions.findIndex((d) => d.divisionId === division.divisionId);
const prevDiv = currentDivIndex > 0 ? allDivisions[currentDivIndex - 1] : null;
const nextDiv = currentDivIndex < allDivisions.length - 1 ? allDivisions[currentDivIndex + 1] : null;

const partTextColors: Record<number, string> = {
  1: 'text-blue-800',
  2: 'text-emerald-800',
  3: 'text-green-700',
  4: 'text-red-700',
  5: 'text-violet-700',
  6: 'text-orange-700',
  7: 'text-cyan-700',
  8: 'text-indigo-700',
  9: 'text-pink-700',
  10: 'text-amber-700',
};
const partAccentText = partTextColors[division.partNumber];

---

<BaseLayout title={`Division ${division.romanNumeral}: ${division.title} - Propaedia`} currentPartNumber={division.partNumber} currentDivisionId={division.divisionId}>
    <main id="main-content" class="flex-1 min-w-0">
      <StickySubheading
        breadcrumbs={[
          {
            label: 'Outline',
            href: `${base}/?explore=specific-topic`,
          },
          {
            label: `Part ${PART_NAMES[division.partNumber]}`,
            compactLabel: PART_ROMAN[division.partNumber],
            compactPriority: 2,
            href: `${base}/part/${division.partNumber}`,
          },
          {
            label: `Division ${division.romanNumeral}`,
            compactLabel: division.romanNumeral,
            compactPriority: 1,
          },
        ]}
        scrollTargets={[
          { id: 'sections', label: 'Sections' },
          { id: 'readings', label: 'Readings' },
        ]}
        colorClass={partTextColors[division.partNumber]}
      />

      <div class="px-4 sm:px-8 py-6">
      <header class="mb-10">
        <h1 class="text-3xl sm:text-4xl font-serif font-bold text-gray-900" data-pagefind-meta={`title:Division ${division.romanNumeral}: ${division.title}`}>
          {division.title}
        </h1>
        <span data-pagefind-meta="page_type:Division" class="hidden"></span>
        <span data-pagefind-meta={`page_context:Part ${PART_NAMES[division.partNumber]}: ${parentPart?.title ?? ''}`} class="hidden"></span>
      </header>

      <NotesDisclosure
        paragraphs={division.headnote ?? []}
        baseUrl={base}
        currentHref={`${base}/division/${division.divisionId}`}
      />

      <!-- Sections List -->
      <section id="sections" class="scroll-mt-24">
        <h2 class="text-2xl font-sans font-bold text-gray-800 mb-6">Sections</h2>
        <div class="space-y-3">
          {sections.map((sec) => (
            <a href={`${base}/section/${sec.sectionCode.replace(/\//g, '-')}`}
              class="group block rounded-2xl border border-slate-200 bg-white px-4 py-4 shadow-sm shadow-slate-100 transition-all hover:-translate-y-0.5 hover:border-slate-300 hover:shadow-md">
              <div class="flex flex-wrap items-start justify-between gap-2">
                <p class={`text-[0.68rem] font-sans font-semibold uppercase tracking-[0.18em] ${partAccentText}`}>
                  Section {sec.sectionCodeDisplay}
                </p>
                <div class="flex shrink-0 items-center gap-3 pl-2">
                  <span class="rounded-full border border-slate-200 bg-slate-50 px-2.5 py-1 text-xs font-medium text-slate-600">
                    {(topLevelSubsectionCountBySection.get(sec.sectionCode) ?? 0)} {(topLevelSubsectionCountBySection.get(sec.sectionCode) ?? 0) === 1 ? 'Subsection' : 'Subsections'}
                  </span>
                  <svg class="mt-1 h-4 w-4 shrink-0 text-slate-300 transition group-hover:text-slate-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                  </svg>
                </div>
              </div>
              <h3 class="mt-2 text-lg font-serif font-bold text-slate-900 transition-colors group-hover:text-slate-950">
                {sec.title}
              </h3>
            </a>
          ))}
        </div>
      </section>

      {(divReadings || divisionIotReadings.length > 0) && (
        <section id="readings" class="mt-10 scroll-mt-24">
          <TopReadings
            client:only="preact"
            vsi={divisionVsiReadings}
            wiki={divisionWikiReadings}
            iot={divisionCuratedIotReadings ?? divisionIotReadings}
            macro={divReadings?.macro}
            baseUrl={base}
            contextLabel="this Division"
            countLabel="Sections"
          >
            <ReadingRecommendationsFallback slot="fallback" />
          </TopReadings>
        </section>
      )}

      {(prevDiv || nextDiv) && (
        <nav class="mt-12 flex items-stretch gap-3 border-t border-slate-200 pt-6" aria-label="Division navigation">
          {prevDiv ? (
            <a
              href={`${base}/division/${prevDiv.divisionId}`}
              class="group flex min-w-0 flex-1 items-center gap-2 rounded-xl border border-slate-200 px-4 py-3 transition hover:border-slate-300 hover:bg-slate-50"
            >
              <svg class="h-4 w-4 shrink-0 text-slate-400 group-hover:text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
              </svg>
              <div class="min-w-0">
                <p class="text-xs font-sans font-semibold uppercase tracking-wide text-slate-400">Previous</p>
                <p class="truncate text-sm font-serif font-semibold text-slate-700 group-hover:text-slate-900">{prevDiv.title}</p>
              </div>
            </a>
          ) : <div class="flex-1" />}
          {nextDiv ? (
            <a
              href={`${base}/division/${nextDiv.divisionId}`}
              class="group flex min-w-0 flex-1 items-center justify-end gap-2 rounded-xl border border-slate-200 px-4 py-3 text-right transition hover:border-slate-300 hover:bg-slate-50"
            >
              <div class="min-w-0">
                <p class="text-xs font-sans font-semibold uppercase tracking-wide text-slate-400">Next</p>
                <p class="truncate text-sm font-serif font-semibold text-slate-700 group-hover:text-slate-900">{nextDiv.title}</p>
              </div>
              <svg class="h-4 w-4 shrink-0 text-slate-400 group-hover:text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          ) : <div class="flex-1" />}
        </nav>
      )}
      </div>
    </main>
</BaseLayout>
