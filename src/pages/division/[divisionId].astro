---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import Breadcrumbs from '../../components/layout/Breadcrumbs.astro';
import NotesDisclosure from '../../components/content/NotesDisclosure.astro';
import navigation from '../../data/navigation.json';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const divisions = await getCollection('divisions');
  return divisions.map((div) => ({
    params: { divisionId: div.data.divisionId },
    props: { division: div.data },
  }));
}

const { division } = Astro.props;
const base = import.meta.env.BASE_URL;

const PART_NAMES: Record<number, string> = {
  1: 'One', 2: 'Two', 3: 'Three', 4: 'Four', 5: 'Five',
  6: 'Six', 7: 'Seven', 8: 'Eight', 9: 'Nine', 10: 'Ten',
};

// Find parent part info
const parentPart = navigation.parts.find((p) => p.partNumber === division.partNumber);
const divNav = parentPart?.divisions.find((d) => d.divisionId === division.divisionId);
const sections = divNav?.sections ?? [];

const partTextColors: Record<number, string> = {
  1: 'text-blue-800',
  2: 'text-emerald-800',
  3: 'text-green-700',
  4: 'text-red-700',
  5: 'text-violet-700',
  6: 'text-orange-700',
  7: 'text-cyan-700',
  8: 'text-indigo-700',
  9: 'text-pink-700',
  10: 'text-amber-700',
};

const breadcrumbItems = [
  { label: 'Home', href: `${base}/` },
  { label: `Part ${PART_NAMES[division.partNumber]}: ${parentPart?.title ?? ''}`, href: `${base}/part/${division.partNumber}` },
  { label: `Division ${division.romanNumeral}: ${division.title}` },
];
---

<BaseLayout title={`Division ${division.romanNumeral}: ${division.title} — Propaedia`} currentPartNumber={division.partNumber} currentDivisionId={division.divisionId}>
    <main id="main-content" class="flex-1 min-w-0 px-4 sm:px-8 py-6">
      <Breadcrumbs items={breadcrumbItems} />

      <header class="mb-10">
        <p class={`text-sm font-sans font-medium uppercase tracking-wide mb-1 ${partTextColors[division.partNumber]}`}>
          Part {PART_NAMES[division.partNumber]}: {parentPart?.title} &middot; Division {division.romanNumeral}
        </p>
        <h1 class="text-4xl font-serif font-bold text-gray-900">
          {division.title}
        </h1>
      </header>

      <NotesDisclosure
        paragraphs={division.headnote ?? []}
        baseUrl={base}
        currentHref={`${base}/division/${division.divisionId}`}
      />

      <!-- Sections List -->
      <section>
        <h2 class="text-2xl font-sans font-bold text-gray-800 mb-6">Sections</h2>
        <div class="space-y-3">
          {sections.map((sec) => (
            <a href={`${base}/section/${sec.sectionCode.replace(/\//g, '-')}`}
              class="block rounded-lg border border-gray-200 p-4 transition-all hover:border-gray-400 hover:shadow-sm">
              <div class="flex items-start gap-3">
                <span class="font-mono text-sm font-semibold text-gray-500 mt-0.5 shrink-0">
                  {sec.sectionCode}
                </span>
                <h3 class="text-lg font-serif font-bold text-gray-900">
                  {sec.title}
                </h3>
              </div>
            </a>
          ))}
        </div>
      </section>
    </main>
</BaseLayout>
